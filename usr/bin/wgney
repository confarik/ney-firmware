#!/bin/bash
export LASTCMD=$@
# Загрузка настроек языка
LANGUAGE_CONFIG="/etc/language-ney.conf"
if [ -f "$LANGUAGE_CONFIG" ]; then
  source "$LANGUAGE_CONFIG"
else
  LANGUAGE="EN"
fi

# Установка локали в зависимости от выбранного языка
if [ "$LANGUAGE" = "RU" ]; then
  # Если выбран русский, проверяем наличие русской локали
  if locale -a 2>/dev/null | grep -q 'ru_RU.utf8\|ru_RU.UTF-8'; then
    export LC_ALL=ru_RU.UTF-8
    export LANG=ru_RU.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
else
  # Если выбран английский, используем английскую локаль
  if locale -a 2>/dev/null | grep -q 'en_US.utf8\|en_US.UTF-8'; then
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
fi
#######################################################################
#
#  /$$      /$$
# | $$$    /$$$
# | $$$$  /$$$$  /$$$$$$   /$$$$$$   /$$$$$$$
# | $$ $$/$$ $$ |____  $$ /$$__  $$ /$$_____/
# | $$  $$$| $$  /$$$$$$$| $$  \__/|  $$$$$$
# | $$\  $ | $$ /$$__  $$| $$       \____  $$
# | $$ \/  | $$|  $$$$$$$| $$       /$$$$$$$/
# |__/     |__/ \_______/|__/      |_______/
#
# Telegram: @confxwho
#######################################################################
rz='\033[1;31m' #'$rz'
mrz='\033[1;91m' #'$mrz'
gz='\033[1;32m' #'$gz'
yz='\033[1;33m' #'$yz'
myz='\033[1;93m' #'$myz'
skyz='\033[1;36m' #'$skyz'
bz='\033[44;37m' #'$bz'
zsh='\033[1m' #'$zsh'
blink='\033[5;33m' # Мигающий желтый текст
endc='\033[0m' #'$endc'

QUIET_MODE=false
if [ "$1" = "-q" ]; then
  QUIET_MODE=true
  shift
fi

if ! $QUIET_MODE; then
  echo -e =========='|'$bz' WGNey 2.0 '$endc'|'=========
fi

if [ "$LANGUAGE" = "RU" ]; then
    CONTACT="[*] ${skyz}Телеграм${endc} контакт: ${yz}@confxwho${endc}
[*]          канал: ${yz}@confxwho${endc}"
else
    CONTACT="[*] ${skyz}Telegram${endc} contact: ${yz}@confxwho${endc}
[*]          channel: ${yz}@confxwho${endc}"
fi
SERIALNEYPI=$(grep -oP 'Serial\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
REVISIONNEYPI=$(grep -oP 'Revision\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
SERIAL_FILE="/etc/security/${SERIALNEYPI}"
if [[ $SERIALNEYPI != a6bb65ad2ae10c15 ]] || [[ $REVISIONNEYPI != b04171 ]] || \
   [[ ! -f "$SERIAL_FILE" ]] || [[ "$(cat "$SERIAL_FILE" 2>/dev/null)" != "$SERIALNEYPI" ]]; then
     echo -e "$CONTACT"
     echo =================================
     exit 1
fi

sudo which wg 1>/dev/null ||
{ echo -e [*] ''$yz'You must install WireGuard.'$endc'' ; exit 1 ; }

HOMENEY=/home/ney
DIRWG=/etc/wireguard
HISTORY=/etc/history-vpn-proxy
case $1 in
    manager)
    WG_STATUS=""
    if ip link show 2>/dev/null | grep -qE "wg0"; then
      WG_STATUS=$(
[ "$LANGUAGE" = "RU" ] && echo "[*] WireGuard VPN-клиент: ОНЛАЙН" || echo "[*] WireGuard VPN-client: ONLINE"
[ "$LANGUAGE" = "RU" ] && echo "[*] Сервер IP/Host: $(sudo grep -oP '^Endpoint\s*=\s*\K.*' /etc/wireguard/wg0.conf 2>/dev/null)" || echo "[*] Server IP/Host: $(sudo grep -oP '^Endpoint\s*=\s*\K.*' /etc/wireguard/wg0.conf 2>/dev/null)"
      )
    else
      [ "$LANGUAGE" = "RU" ] && WG_STATUS="[*] WireGuard VPN-клиент: ОФФЛАЙН" || WG_STATUS="[*] WireGuard VPN-client: OFFLINE"
    fi
    
    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
$WG_STATUS

enter: подключить
n: подключить новый конфиг
s: остановить
e: редактировать конфиг
a: включить автоподключение
r: включить автоподключение-рандом
d: отключить автоподключение
j: журнал подключения
h: история подключений
delete: удалить конфиг
ctrl-i: импортировать все конфиги
ctrl-e: экспортировать все конфиги
ESC: выход"
      EXIT_MSG="Для выхода нажмите любую клавишу"
      BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
    else
      FZF_HEADER="
$WG_STATUS

enter: connect saved config
n: connect new config
s: stop
e: edit config
a: enable autostart
r: enable autostart-random
d: disable autostart
j: show connection journal
h: connection history
delete: delete config
ctrl-i: import all configs
ctrl-e: export all configs
ESC: exit"
      EXIT_MSG="Press any key to exit"
      BORDER_LABEL="| WireGuard VPN-Client manager |"
    fi

    (for CONFIG in $(sudo ls $DIRWG 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do
        if [ "$CONFIG" != "wg0.conf" ]; then
          if [ -f "/etc/network/if-up.d/autorandomwg" ]; then
            echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"
          elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then
            echo -e "$CONFIG \033[44;37m(auto)\033[0m"
          else
            echo "$CONFIG"
          fi
        else
            echo "$CONFIG"
        fi
    done) | fzf --ansi --style default  --preview 'cat -n /etc/wireguard/$(echo {} | cut -d" " -f1)' \
      --header="$FZF_HEADER" \
      --bind='n:execute(wgney -q start; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(wgney -q manager)' \
      --bind='enter:execute(wgney -q start $(echo {} | cut -d" " -f1); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(wgney -q manager)' \
      --bind='s:execute-silent(sudo wgney stop && sleep 1)+become(wgney -q manager)' \
      --bind='e:execute(sudo nano -l -m /etc/wireguard/$(echo {} | cut -d" " -f1))' \
      --bind='e:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='a:execute-silent(sudo wgney enable $(echo {} | cut -d" " -f1))' \
      --bind='a:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='r:execute-silent(sudo wgney random)' \
      --bind='r:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='d:execute-silent(sudo wgney disable)' \
      --bind='d:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='j:execute(wgney -q -j $(echo {} | cut -d" " -f1); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(wgney -q manager)' \
      --bind='h:execute(wgney -q history && sleep 2)+become(wgney -q manager)' \
      --bind='delete:execute-silent(sudo wgney -rm $(echo {} | cut -d" " -f1))' \
      --bind='delete:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='ctrl-i:execute(sudo wgney -q import; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+become(wgney -q manager)' \
      --bind='ctrl-e:execute(sudo wgney -q export; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+reload(wgney -q manager)' \
      --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
      --height=65% --info=inline --margin=1 --padding=1
    if ! $QUIET_MODE; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
      echo =================================
    fi
    shift
    exit 1 ;;

    up|start)
    configwg="$2"
    if [ -f "$HOMENEY/$configwg" ]; then
      sudo mv $configwg $DIRWG
      sudo chmod 644 $DIRWG/$configwg
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Файл конфига WireGuard ${zsh}$configwg${endc} перемещен в папку $DIRWG" || echo -e "[*] ${gz}Done:${endc} WireGuard config file ${zsh}$configwg${endc} moved to $DIRWG"
    fi
    if [ -n "$configwg" ]; then
      sudo cp $DIRWG/$configwg $DIRWG/wg0.conf
      sudo chmod 644 $DIRWG/wg0.conf
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выбран конфиг WireGuard ${zsh}$configwg${endc}." || echo -e "[*] Selected WireGuard config ${zsh}$configwg${endc}"
      sudo ifconfig wg0 1>/dev/null 2>&1
      if [ "$?" != "1" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Рестарт...${endc}" || echo -e "[*] ${yz}Restart...${endc}"
        sudo wg-quick down wg0 1>/dev/null 2>&1
        sleep 1
      fi
      wgname=$(sudo cat $DIRWG/wg0.conf | grep Endpoint | cut -d= -f2)
      TIME=15
      [ "$LANGUAGE" = "RU" ] && echo -n "[*] Подключаемся к $wgname." || echo -n "[*] Connecting to $wgname."
      sudo wg-quick up wg0 1>/dev/null 2>&1
      i=0
      while [ $i -lt $TIME ];
      do
        sleep 1
        echo -n "."
        i=$(( $i + 1 ))
        conwg=$(ifconfig | grep wg0 | awk '{print $1}' | head -c-2)
        if ! test -z "$conwg" ; then
          echo
          [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Подключено" || echo -e "[*] ${gz}Done:${endc} Connected"
          [ "$LANGUAGE" = "RU" ] && echo -e "[*] Время: `date +%T` `date +%d-%m-%Y`" || echo -e "[*] Time: `date +%T` `date +%d-%m-%Y`"
          echo -e "`date +%T`  `date +%d-%m-%Y`  VALID = wgney $LASTCMD" | sed 's/ -q//' >> $HISTORY/wgney-h
          break
        fi
      done
      if test -z "$conwg" ; then
        echo
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Информация: не удалось подключиться к серверу по WireGuard VPN.${endc}" || echo -e "[*] ${rz}Information: failed to connect to the server by WireGuard VPN.${endc}"
        echo -e "`date +%T`  `date +%d-%m-%Y`  NO VALID = wgney $LASTCMD" | sed 's/ -q//' >> $HISTORY/wgney-h
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}По этой причине ниже открыт журнал событий этого конфига WireGuard VPN:${endc}" || echo -e "[*] ${yz}By this reason, the event log of this WireGuard VPN config is opened below:${endc}"
        sudo wg-quick up $DIRWG/wg0.conf
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Закрыт журнал. Отправьте скриншот журнала Neyу, если вы не разбираетесь в журнале${endc}" || echo -e "[*] ${yz}Closed log. Send a screenshot of the Ney log if you don't understand the log${endc}"
      fi  
      echo =================================
    else
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: подключить новый конфиг
ESC: выход"
        BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
      else
        FZF_HEADER="
enter: connect new config 
ESC: exit"
        BORDER_LABEL="| WireGuard VPN-client manager |"
      fi
      configwg=$(ls -l $HOMENEY/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r | fzf --ansi --style default --preview 'cat -n /home/ney/{}' \
        --header="$FZF_HEADER" \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$configwg" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      else
        sudo wgney start $configwg
      fi
    fi
    shift
    exit 1 ;;
    down|stop|-s)
    sudo wg-quick down wg0 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} WireGuard VPN отсоединен." || echo -e "[*] ${gz}Done:${endc} WireGuard VPN disconnected."
    echo =================================
    shift
    exit 1 ;;
    random)
    # Сначала активируем механизм случайного выбора
    sudo touch /etc/network/if-up.d/autorandomwg 1>/dev/null 2>&1
cat << 'EOF' > /etc/network/if-up.d/autorandomwg
#!/bin/sh
autorandomwg=$(sudo ls /etc/wireguard/ | shuf -n1) && sudo cp /etc/wireguard/$autorandomwg /etc/wireguard/wg0.conf
EOF
    sudo chmod +x /etc/network/if-up.d/autorandomwg
    # Затем сразу же запускаем случайный выбор, чтобы очистить любое предыдущее состояние и обновить wg0.conf
    random_config=$(sudo ls /etc/wireguard/ | shuf -n1)
    sudo cp $DIRWG/$random_config $DIRWG/wg0.conf 1>/dev/null 2>&1
    sudo chmod 644 $DIRWG/wg0.conf 1>/dev/null 2>&1
    # Включаем автозапуск
    sudo systemctl enable wg-quick@wg0 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Включен случайный выбор конфига WireGuard при запуске малины." || echo -e "[*] ${gz}Done:${endc} Enabled random selection of WireGuard config on boot."
    echo =================================
    shift
    exit 1 ;;
    enable)
    configwg="$2"
    if [ ! -f "$DIRWG/$configwg" ]; then
      configwg=$(
        (for CONFIG in $(sudo ls $DIRWG 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do
          if [ "$CONFIG" != "wg0.conf" ]; then
            if [ -f "/etc/network/if-up.d/autorandomwg" ]; then
              echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"
            elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then
              echo -e "$CONFIG \033[44;37m(auto)\033[0m"
            else
              echo "$CONFIG"
            fi
          else
              echo "$CONFIG"
          fi

        if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: выбрать конфиг для автоподключения
r: включить автоподключение-рандом
d: выключить автоподключение
ESC: выход"
        BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
      else
        FZF_HEADER="
enter select config for autoconnect
r: enable auto-random
d: disable auto
ESC: exit"
        BORDER_LABEL="| WireGuard VPN-client manager |"
      fi
        done) | fzf --ansi --style default  --preview 'cat -n /etc/wireguard/$(echo {} | cut -d" " -f1)' \
        --header="$FZF_HEADER" \
        --bind='enter:execute-silent(sudo wgney enable $(echo {} | cut -d" " -f1))' \
        --bind='enter:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
        --bind='r:execute-silent(sudo wgney random)' \
        --bind='r:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
        --bind='d:execute-silent(sudo wgney disable)' \
        --bind='d:+reload(for CONFIG in $(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "wg0.conf" ]; then if [ -f "/etc/network/if-up.d/autorandomwg" ]; then echo -e "$CONFIG \033[44;37m(auto-random)\033[0m"; elif systemctl is-enabled wg-quick@wg0 &>/dev/null && [ -f "/etc/wireguard/wg0.conf" ] && diff -q "/etc/wireguard/$CONFIG" "/etc/wireguard/wg0.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$configwg" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      fi
    fi
    # Отключаем режим auto-random, если он был активирован
    if [ -f "/etc/network/if-up.d/autorandomwg" ]; then
        sudo rm -f /etc/network/if-up.d/autorandomwg 1>/dev/null 2>&1
        echo -e "[*] ${gz}Успешно:${endc} Отключен режим случайного выбора конфига."
    fi
    sudo cp $DIRWG/$configwg $DIRWG/wg0.conf
    sudo chmod 644 $DIRWG/wg0.conf
    sudo systemctl enable wg-quick@wg0 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} При вкл малины конфиг WireGuard ${zsh}$configwg${endc} автоматически подключается." || echo -e "[*] ${gz}Done:${endc} Config WireGuard ${zsh}$configwg${endc} will be automatically connected on boot."
    echo =================================
    shift
    exit 1 ;;
    disable)
    sudo rm -rf /etc/network/if-up.d/autorandomwg 1>/dev/null 2>&1
    sudo systemctl disable wg-quick@wg0 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Отключено автоподключение WireGuard VPN при вкл малины." || echo -e "[*] ${gz}Done:${endc} WireGuard VPN autostart disabled."
    echo =================================
    shift
    exit 1 ;;
    -j)
    configwg="$2"
    if [ -f "$HOMENEY/$configwg" ]; then
      sudo mv $configwg $DIRWG
      sudo chmod 644 $DIRWG/$configwg
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Файл конфига WireGuard ${zsh}$configwg${endc} перемещен в папку $DIRWG" || echo -e "[*] ${gz}Done:${endc} WireGuard config file ${zsh}$configwg${endc} moved to $DIRWG"
    fi
    if [ ! -f "$DIRWG/$configwg" ]; then
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: показать журнал подключения
ESC: выход"
        BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
      else
        FZF_HEADER="
enter: show connection journal
ESC: exit"
        BORDER_LABEL="| WireGuard VPN-client manager |"
      fi
      configwg=$(sudo ls -l $DIRWG 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r | fzf --ansi --style default --preview 'cat -n /etc/wireguard/{}' \
        --header="$FZF_HEADER" \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$configwg" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      fi
    fi
    sudo ifconfig wg0 1>/dev/null 2>&1
    if [ "$?" != "1" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Рестарт...${endc}" || echo -e "[*] ${yz}Restart...${endc}"
      sudo wg-quick down wg0 1>/dev/null 2>&1
      sleep 1
    fi
    sudo cp $DIRWG/$configwg $DIRWG/wg0.conf
    sudo chmod 644 $DIRWG/wg0.conf
    sudo wg-quick up $DIRWG/wg0.conf
    echo [*]
    if ! $QUIET_MODE; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
      echo =================================
    fi
    shift
    exit 1 ;;
    -ls)
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${zsh}Список конфигов WireGuard VPN:${endc}" || echo -e "[*] ${zsh}WireGuard VPN config list:${endc}"
    sudo ls -1 /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev
    echo =================================
    shift
    exit 1 ;;
    -mv)
    configwg="$2"
    if [ ! -f "$HOMENEY/$configwg" ]; then
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: переместить конфиг в /etc/wireguard
ESC: выход"
        BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
      else
        FZF_HEADER="
enter: move config to /etc/wireguard
ESC: exit"
        BORDER_LABEL="| WireGuard VPN-client manager |"
      fi
      (ls -l $HOMENEY/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r) | fzf --ansi --style default --preview 'cat -n /home/ney/{}' \
        --header="$FZF_HEADER" \
        --bind='enter:execute-silent(sudo wgney -mv {})' \
        --bind='enter:+reload(ls /home/ney/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r)' \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
    else
      sudo mv $configwg $DIRWG
      sudo chmod 644 $DIRWG/$configwg
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Файл конфига WireGuard ${zsh}$configwg${endc} перемещен в папку $DIRWG" || echo -e "[*] ${gz}Done:${endc} WireGuard config file ${zsh}$configwg${endc} moved to $DIRWG"
    fi
    echo =================================
    shift
    exit 1 ;;
    -rm)
    configwg="$2"
    if [ ! -f "$DIRWG/$configwg" ]; then
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: удалить конфиг
a: удалить все конфиги
ESC: выход"
        BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
      else
        FZF_HEADER="
enter: delete conf
a: delete all confs
ESC: exit"
        BORDER_LABEL="| WireGuard VPN-client manager |"
      fi
      (sudo ls $DIRWG 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r) | fzf --ansi --style default --preview 'cat -n /etc/wireguard/{}' \
        --header="$FZF_HEADER" \
        --bind='enter:execute-silent(sudo wgney -rm {})' \
        --bind='enter:+reload(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r)' \
        --bind='a:execute-silent(sudo wgney -rm-all)' \
        --bind='a:+reload(sudo ls /etc/wireguard 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r)' \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
      echo =================================
      exit 1
    else
      sudo rm $DIRWG/$configwg
      sudo touch $DIRWG/wg0.conf 1>/dev/null 2>&1
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Конфиг WireGuard ${zsh}$configwg${endc} удален" || echo -e "[*] ${gz}Done:${endc} WireGuard config ${zsh}$configwg${endc} deleted"
    fi
    echo =================================
    shift
    exit 1 ;;
    -rm-all)
    sudo rm -rf $DIRWG/*.conf 1>/dev/null 2>&1
    sudo touch $DIRWG/wg0.conf 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Все конфиги WireGuard удалены" || echo -e "[*] ${gz}Done:${endc} All WireGuard configs deleted"
    echo =================================
    shift
    exit 1 ;;
    history)
    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
enter: подключить
a: очистить историю подключений
ESC: выход"
      BORDER_LABEL="| Менеджер WireGuard VPN-клиент |"
    else
      FZF_HEADER="
enter: re-connect
a: clear connection history
ESC: exit"
      BORDER_LABEL="| WireGuard VPN-client manager |"
    fi
    HISTORYWG=$(cat $HISTORY/wgney-h 2>/dev/null | sort -r -k2,2 | sed "s/NO VALID/$(echo -e "$rz")NO VALID$(echo -e "$endc")/g" | sed "s/  VALID/$(echo -e "$gz")  VALID$(echo -e "$endc")/g" | fzf --ansi \
      --header="$FZF_HEADER" \
      --bind='a:become(echo > /etc/history-vpn-proxy/wgney-h 1>/dev/null 2>&1)' \
      --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
      --height=40% --info=inline --margin=1 --padding=1)
    if [ -z "$HISTORYWG" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
      echo =================================
      exit 1
    fi
    TUWG=$(echo "$HISTORYWG" | cut -d= -f2)
    echo 'sudo'$TUWG''
    sudo $TUWG
    shift
    exit 1
    ;;
    clear)
    sudo sh -c "echo > $HISTORY/wgney-h 1>/dev/null 2>&1"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} История очищена." || echo -e "[*] ${gz}Done:${endc} History cleared."
    echo =================================
    shift
    exit 1
    ;;
    import)
    if [ ! "$(ls -A $HOMENEY/wireguard-backup/*.conf 2>/dev/null)" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось найти папку wireguard-backup.${endc}" || echo -e "[*] ${rz}Error: failed to find wireguard-backup directory.${endc}"
      echo =================================
      exit 1
    fi
    sudo cp $HOMENEY/wireguard-backup/* $DIRWG 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Импорт выполнен." || echo -e "[*] ${gz}Done:${endc} Import completed."
    echo =================================
    shift
    exit 1 ;;
    export)
    sudo mkdir -p $HOMENEY/wireguard-backup 1>/dev/null 2>&1
    sudo cp $DIRWG/*.conf $HOMENEY/wireguard-backup 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Экспорт выполнен. Папка wireguard-backup в домашней папке." || echo -e "[*] ${gz}Done:${endc} Export completed. wireguard-backup directory in home directory."
    echo =================================
    shift
    exit 1 ;;
    *)
    if [ "$LANGUAGE" = "RU" ]; then
cat << EOF
[*] Использование: sudo wgney [опции]
[*] Опции:
[*]  manager           - менеджер WireGuard VPN-клиент
[*]  start             - подключить новый конфиг
[*]  start [конфиг]    - подключить сохраненный конфиг (можно не ввести конфиг)
[*]  stop              - отсоединить
[*]  random            - включить случайный выбор конфига при запуске малины
[*]  enable [конфиг]   - включить автоподключение при вкл малины (можно не ввести конфиг)
[*]  disable           - отключить автоподключение при вкл малины
[*]  -j                - показать журнал подключения (можно не ввести конфиг)
[*]  -ls               - cписок конфигов
[*]  -mv [конфиг]      - переместить конфиг в папку /etc/wireguard (можно не ввести конфиг)
[*]  -rm [конфиг]      - удалить конфиг (можно не ввести конфиг)
[*]  -rm-all           - удалить все конфиги
[*]  history           - история подключений
[*]  clear             - очистить историю подключений
[*]  import            - импортировать все конфиги в /etc/wireguard
[*]  export            - экспортировать все конфиги в домашнюю папку
[*]
[*]   Как скинуть конфиг WireGuard на малину:
[*]   1. Удалить пробелы, скобки из имени файла, если есть.
[*]   2. Скинуть конфиг на малину в домашнюю папку /home/pi
[*]      через SFTP(есть в битваисе кнопка "New SFTP window" в левой колонне,
[*]      а для MacOS бесплатая программа ForkLift) или SCP.
[*]
[*] Контакт: телеграм @confxwho (никнейм: Ney)
EOF
    else
      cat << EOF
[*] Usage: sudo wgney [options]
[*] Options:
[*]  manager           - WireGuard VPN-client manager
[*]  start             - connect new config
[*]  start [config]    - connect saved config (can don't have to enter config)
[*]  stop              - disconnect
[*]  random            - enable random config selection on boot
[*]  enable [config]   - enable autoconnect on boot (can don't have to enter config)
[*]  disable           - disable autoconnect on boot
[*]  -j                - show connection journal
[*]  -ls               - list configs
[*]  -mv [config]      - move config to /etc/wireguard (can don't have to enter config)
[*]  -rm [config]      - remove config (can don't have to enter config)
[*]  -rm-all           - remove all configs
[*]  history           - connection history
[*]  clear             - clear connection history
[*]  import            - import all configs to /etc/wireguard
[*]  export            - export all configs to home directory
[*]
[*]   How to send WireGuard config to Raspberry Pi and start:
[*]   1. Remove spaces, brackets from the config file name, if any.
[*]   2. Send the config to the Raspberry Pi's home directory
[*]      /home/pi through SFTP(there is a button "New SFTP window" in the left column in Bitvise,
[*]      or a free program ForkLift for MacOS) or SCP.
[*]
[*] Contact: telegram @confxwho (nickname: Ney)
EOF
    fi
    echo =================================
    shift
    exit 1 ;;
esac
