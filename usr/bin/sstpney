#!/bin/bash
export LASTCMD=$@

# Загрузка настроек языка
LANGUAGE_CONFIG="/etc/language-ney.conf"
if [ -f "$LANGUAGE_CONFIG" ]; then
  source "$LANGUAGE_CONFIG"
else
  LANGUAGE="EN"
fi

# Установка локали в зависимости от выбранного языка
if [ "$LANGUAGE" = "RU" ]; then
  # Если выбран русский, проверяем наличие русской локали
  if locale -a 2>/dev/null | grep -q 'ru_RU.utf8\|ru_RU.UTF-8'; then
    export LC_ALL=ru_RU.UTF-8
    export LANG=ru_RU.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
else
  # Если выбран английский, используем английскую локаль
  if locale -a 2>/dev/null | grep -q 'en_US.utf8\|en_US.UTF-8'; then
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
fi
#######################################################################
#
#  /$$      /$$
# | $$$    /$$$
# | $$$$  /$$$$  /$$$$$$   /$$$$$$   /$$$$$$$
# | $$ $$/$$ $$ |____  $$ /$$__  $$ /$$_____/
# | $$  $$$| $$  /$$$$$$$| $$  \__/|  $$$$$$
# | $$\  $ | $$ /$$__  $$| $$       \____  $$
# | $$ \/  | $$|  $$$$$$$| $$       /$$$$$$$/
# |__/     |__/ \_______/|__/      |_______/
#
# Telegram: @confxwho
#######################################################################
rz='\033[1;31m' #'$rz'
mrz='\033[1;91m' #'$mrz'
gz='\033[1;32m' #'$gz'
yz='\033[1;33m' #'$yz'
myz='\033[1;93m' #'$myz'
skyz='\033[1;36m' #'$skyz'
bz='\033[44;37m' #'$bz'
zsh='\033[1m' #'$zsh'
blink='\033[5;33m' # Мигающий желтый текст
endc='\033[0m' #'$endc'

QUIET_MODE=false
if [ "$1" = "-q" ]; then
  QUIET_MODE=true
  shift
fi

if ! $QUIET_MODE; then
echo -e ========='|'$bz' SSTPNey 2.1 '$endc'|'========
fi

if [ "$LANGUAGE" = "RU" ]; then
    CONTACT="[*] ${skyz}Телеграм${endc} контакт: ${yz}@confxwho${endc}
[*]          канал: ${yz}@confxwho${endc}"
else
    CONTACT="[*] ${skyz}Telegram${endc} contact: ${yz}@confxwho${endc}
[*]          channel: ${yz}@confxwho${endc}"
fi
SERIALNEYPI=$(grep -oP 'Serial\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
REVISIONNEYPI=$(grep -oP 'Revision\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
SERIAL_FILE="/etc/security/${SERIALNEYPI}"
if [[ $SERIALNEYPI != a6bb65ad2ae10c15 ]] || [[ $REVISIONNEYPI != b04171 ]] || \
   [[ ! -f "$SERIAL_FILE" ]] || [[ "$(cat "$SERIAL_FILE" 2>/dev/null)" != "$SERIALNEYPI" ]]; then
     echo -e "$CONTACT"
     echo =================================
     exit 1
fi

TIME=13
HOMENEY=/home/ney
HISTORY=/etc/history-vpn-proxy
# Функция для проверки, является ли строка IP-адресом или хостом
is_ip_or_host() {
  local check_str=$1
  local host_part=${check_str%:*}
  [[ -z "$check_str" ]] && return 1
  if [[ $host_part =~ ^[0-9.]+$ ]]; then
    [[ $host_part =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]] && return 0
    return 1
  fi
  [[ $host_part == *"."* && $host_part != *" "* && ! $host_part =~ ^[0-9.]+$ ]] && return 0
  return 1
}
# Функция для получения короткого IP (последняя половина)
get_short_ip() {
    local ip=$1
    if [[ $ip =~ ^([0-9]+\.[0-9]+)\.([0-9]+\.[0-9]+)$ ]]; then
        echo "${BASH_REMATCH[2]}"
    else
        echo "$ip"
    fi
}
stop_sstpney() {
  DELIP=$(route -n | grep UGH | awk '{print $1}') 1>/dev/null 2>&1
  sudo poff ${0##*/} 1>/dev/null 2>&1
  sudo route delete $DELIP 1>/dev/null 2>&1
  sleep 1
  sudo killall -9 pppd 1>/dev/null 2>&1
}
case $1 in
    manager)
    SSTP_CONNECTED=$(sudo bash -c 'ps aux | grep "sstpc" | grep -v grep || echo false')
    if [ "$SSTP_CONNECTED" = "false" ]; then
      [ "$LANGUAGE" = "RU" ] && SSTP_CONNECTED="не подключено" || SSTP_CONNECTED="not connected"
    else
      [ "$LANGUAGE" = "RU" ] && SSTP_CONNECTED="подключено" || SSTP_CONNECTED="connected"
    fi
    LAST_SERVERIP=$(sudo bash -c 'if [ -f /etc/ppp/peers/sstpney ] && grep -q "pty" /etc/ppp/peers/sstpney; then grep "pty" /etc/ppp/peers/sstpney | awk "{print \$3}"; else echo "N/A"; fi')
    AUTOSTART_SSTP=$(systemctl is-enabled sstpney 2>/dev/null)
    if [ "$AUTOSTART_SSTP" = "disabled" ]; then
      [ "$LANGUAGE" = "RU" ] && AUTOSTART_SSTP="отключено" || AUTOSTART_SSTP="disabled"
    else
      [ "$LANGUAGE" = "RU" ] && AUTOSTART_SSTP="включено" || AUTOSTART_SSTP="enabled"
    fi

    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
[*] SSTP VPN-клиент: $SSTP_CONNECTED - $LAST_SERVERIP
[*]  Автоподключение: $AUTOSTART_SSTP

Enter: подключить
n: подключить новый
u: обновить режим CA
s: остановить
a: включить автоподключение
d: выключить автоподключение
c: очистить историю
ctrl-i: импортировать историю
ctrl-e: экспортировать историю
ESC: выйти"
      EXIT_MSG="Для выхода нажмите любую клавишу"
      BORDER_LABEL="| Менеджер SSTP VPN-клиент |"
    else
      FZF_HEADER="
[*] SSTP VPN-client: $SSTP_CONNECTED - $LAST_SERVERIP
[*]  Autostart: $AUTOSTART_SSTP

Enter: re-connect
n: connect new
u: update mode CA
s: stop
a: enable autostart
d: disable autostart
c: clear history
ctrl-i: import history
ctrl-e: export history
ESC: exit"
      EXIT_MSG="Press any key to exit"
      BORDER_LABEL="| SSTP VPN-client manager |"
    fi

    HISTORYSSTP=$(cat $HISTORY/sstpney-h 2>/dev/null | sort -r -k2,2 | sed "s/NO VALID/$(echo -e "$rz")NO VALID$(echo -e "$endc")/g" | sed "s/  VALID/$(echo -e "$gz")  VALID$(echo -e "$endc")/g" | fzf --ansi \
      --header="$FZF_HEADER" \
      --bind='enter:execute(sudo $(echo {} | cut -d= -f2); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(sstpney -q manager)' \
      --bind='n:execute(sudo sstpney -q new; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(sstpney -q manager)' \
      --bind='u:execute(sudo sstpney -q new $(echo {} | sed -E "s/.*on |.*pon |.*start //" | awk "{for(i=1;i<=NF-(/-ca/?2:0);i++) printf \"%s%s\",\$i,i==NF-(/-ca/?2:0)?\"\\n\":\" \"}"); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(sstpney -q manager)' \
      --bind='s:execute-silent(sudo sstpney -s && sleep 1)+become(sstpney -q manager)' \
      --bind='a:execute-silent(sudo sstpney enable && sleep 1)+become(sstpney -q manager)' \
      --bind='d:execute-silent(sudo sstpney disable && sleep 1)+become(sstpney -q manager)' \
      --bind='c:execute-silent(sudo sstpney clear && sleep 1)+become(sstpney -q manager)' \
      --bind='ctrl-i:execute(sudo sstpney -q import; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+become(sstpney -q manager)' \
      --bind='ctrl-e:execute(sudo sstpney -q export; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+reload(sstpney -q manager)' \
      --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
      --height=40% --info=inline --margin=1 --padding=1)
    if [ -z "$HISTORYSSTP" ]; then
      if ! $QUIET_MODE; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
      fi
      exit 1
    fi
    exit 0
    ;;
    new)
    # Проверяем, есть ли параметры
    if [ $# -ge 2 ]; then
        server_info="$2"
        if [ $# -ge 4 ]; then
            # Формат: IP/Host логин пароль
            SERVERIP="$2"
            SERVERLOGIN="$3"
            SERVERPASS="$4"
        else
            # Проверяем различные форматы с разделителями
            if [[ "$server_info" == *"|"* ]]; then
                IFS='|' read -r part1 part2 part3 <<< "$server_info"
            elif [[ "$server_info" == *":"* ]]; then
                if [[ "$server_info" =~ ^([^:]+:[0-9]+):([^:]+):([^:]+)$ ]]; then
                    # Формат IP/Host:port:login:password
                    part1=${BASH_REMATCH[1]}
                    part2=${BASH_REMATCH[2]}
                    part3=${BASH_REMATCH[3]}
                else
                    IFS=':' read -r part1 part2 part3 <<< "$server_info"
                fi
            else
                [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный формат ввода.${endc}" || echo -e "[*] ${rz}Error: invalid input format.${endc}"
                exit 1
            fi

            # Определяем, что из частей является IP/Host
            if is_ip_or_host "$part1"; then
                SERVERIP=$part1
                SERVERLOGIN=$part2
                SERVERPASS=$part3
            elif is_ip_or_host "$part3"; then
                SERVERLOGIN=$part1
                SERVERPASS=$part2
                SERVERIP=$part3
            else
                [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось определить IP/Host.${endc}" || echo -e "[*] ${rz}Error: could not determine IP/Host.${endc}"
                exit 1
            fi
        fi

        # Проверяем правильность IP/Host
        if ! is_ip_or_host "$SERVERIP"; then
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный формат IP/Host.${endc}" || echo -e "[*] ${rz}Error: invalid IP/Host format.${endc}"
            exit 1
        fi
    else
        # Интерактивный ввод данных
        SERVERIP=""
        SERVERLOGIN=""
        SERVERPASS=""
        while [ -z "$SERVERIP" ] || [ -z "$SERVERLOGIN" ] || [ -z "$SERVERPASS" ]; do
            if [ "$LANGUAGE" = "RU" ]; then
                # Ввод данных сервера в одной строке
                echo -e [*] ''$zsh'Введите данные SSTP VPN в одном из любых форматов:'$endc''
                echo -e [*] '  IP/Host:логин:пароль'
                echo -e [*] '  IP/Host логин пароль'
                echo -e [*] '  IP/Host|логин|пароль'
                echo -e [*] '  логин:пароль:IP/Host'
                echo -e [*] '  логин пароль IP/Host'
                echo -e [*] '  логин|пароль|IP/Host'
                echo -e [*] '  IP/Host:порт логин пароль'
                echo -e [*] '  IP/Host:порт:логин:пароль'
                echo -e [*] '  IP/Host:порт|логин:пароль'
                echo -e [*] '  логин:пароль:IP/Host:порт'
                echo -e [*] '  логин пароль IP/Host:порт'
                echo -e [*] '  логин|пароль|IP/Host:порт'
                echo -e [*]
                read -p "Вставьте или введите данные SSTP VPN: " server_info
            else
                # Ввод данных сервера в одной строке
                echo -e [*] ''$zsh'Enter SSTP VPN data in one of the following formats:'$endc''
                echo -e [*] '  IP/Host:login:password'
                echo -e [*] '  IP/Host login password'
                echo -e [*] '  IP/Host|login|password'
                echo -e [*] '  login:password:IP/Host'
                echo -e [*] '  login password IP/Host'
                echo -e [*] '  login|password|IP/Host'
                echo -e [*] '  IP/Host:port login password'
                echo -e [*] '  IP/Host:port:login:password'
                echo -e [*] '  login:password:IP/Host:port'
                echo -e [*] '  login password IP/Host:port'
                echo -e [*] '  login|password|IP/Host:port'
                echo -e [*]
                read -p "Paste or enter SSTP VPN data: " server_info
            fi

            # Если пользователь нажал Enter без ввода данных
            if [ -z "$server_info" ]; then
                continue
            fi

            # Разбиваем строку на части
            if [[ "$server_info" == *"|"* ]]; then
                # Разделитель - вертикальная черта
                IFS='|' read -r part1 part2 part3 <<< "$server_info"
            elif [[ "$server_info" == *":"* && "$server_info" != *" "* ]]; then
                # Разделитель - двоеточие
                # Специальная обработка для IP/Host:port
                if [[ "$server_info" =~ ^([^:]+:[0-9]+):([^:]+):([^:]+)$ ]]; then
                    # Формат IP/Host:port:login:password
                    part1=${BASH_REMATCH[1]}
                    part2=${BASH_REMATCH[2]}
                    part3=${BASH_REMATCH[3]}
                else
                    IFS=':' read -r part1 part2 part3 <<< "$server_info"
                fi
            else
                # Предполагаем разделитель - пробел
                read -r part1 part2 part3 <<< "$server_info"
            fi

            # Определяем, что из частей является IP/Host и что логином/паролем
            if is_ip_or_host "$part1"; then
                # Формат: IP/Host логин пароль
                SERVERIP=$part1
                SERVERLOGIN=$part2
                SERVERPASS=$part3
            elif is_ip_or_host "$part3"; then
                # Формат: логин пароль IP/Host
                SERVERLOGIN=$part1
                SERVERPASS=$part2
                SERVERIP=$part3
            else
                [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось определить IP/Host в введенной строке.${endc}" || echo -e "[*] ${rz}Error: failed to determine IP/Host in the input string.${endc}"
                SERVERIP=""
                SERVERLOGIN=""
                SERVERPASS=""
                continue
            fi

            # Проверяем наличие всех параметров
            if [ -z "$SERVERIP" ] || [ -z "$SERVERLOGIN" ] || [ -z "$SERVERPASS" ]; then
                [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не все параметры указаны.${endc}" || echo -e "[*] ${rz}Error: not all parameters specified.${endc}"
                SERVERIP=""
                SERVERLOGIN=""
                SERVERPASS=""
                continue
            fi
        done
    fi

    # Проверяем наличие всех необходимых параметров
    if [ -z "$SERVERIP" ] || [ -z "$SERVERLOGIN" ] || [ -z "$SERVERPASS" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не все параметры указаны.${endc}" || echo -e "[*] ${rz}Error: not all parameters specified.${endc}"
        exit 1
    fi
    
    # Интерактивный выбор режима CA
    ca_opt=""
    while [ -z "$ca_opt" ]; do
        if [ "$LANGUAGE" = "RU" ]; then
            FZF_HEADER="
enter: выбрать
ESC: выход
      Режим CA:"
            BORDER_LABEL="| Менеджер SSTP VPN-клиент |"
            INTERACTIVE=" [1]  Без сертификата CA
 [2]  Указать файл CA
 [3]  Ввести содержимое CA"
        else
            FZF_HEADER="
enter: select
ESC: exit
      CA mode:"
            BORDER_LABEL="| SSTP VPN-client manager |"
            INTERACTIVE=" [1]  Without certificate CA
 [2]  Specify CA file
 [3]  Enter CA content"
        fi

        ca_choice=$(echo "$INTERACTIVE" | fzf --ansi --pointer=">" \
            --header="$FZF_HEADER" \
            --bind='enter:become(echo {})' \
            --layout=reverse --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
            --height=30% --info=inline --margin=1 --padding=1)

        # Если пользователь нажал ESC
        [ -z "$ca_choice" ] && exit 1

        case "$ca_choice" in
            *"[1]"*)
                # Без CA
                ca_opt=" "
                ;;
            *"[2]"*)
                # С CA (указать файл)
                if [ "$LANGUAGE" = "RU" ]; then
                    read -p "Введите имя файла CA: " ca_file
                else
                    read -p "Enter CA file name: " ca_file
                fi
                # Проверяем наличие файла в /home/ney
                if [ -f "/home/ney/$ca_file" ]; then
                    ca_opt="-ca \"$ca_file\""
                # Проверяем наличие файла в $HISTORY/sstp
                elif [ -f "$HISTORY/sstp/$ca_file" ]; then
                    ca_opt="-ca \"$ca_file\""
                else
                    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: файл не найден.${endc}" || echo -e "[*] ${rz}Error: CA file not found.${endc}"
                fi
                ;;
            *"[3]"*)
                # С CA (ввести содержимое)
                if [ "$LANGUAGE" = "RU" ]; then
                    echo -e "[*] Вставьте содержимое CA сертификата (нажмите Enter для завершения):"
                else
                    echo -e "[*] Paste CA certificate content (press Enter to finish):"
                fi
                short_ip=$(get_short_ip "$SERVERIP")
                sudo mkdir -p "$HISTORY/sstp"
                sudo rm -f "$HISTORY/sstp/ca_$short_ip.crt"
                while IFS= read -r line; do
                    if [ -z "$line" ]; then
                        break
                    fi
                    echo "$line" | sudo tee -a "$HISTORY/sstp/ca_$short_ip.crt" >/dev/null
                done
                # Проверяем, что файл не пустой и содержит сертификат
                if ! sudo grep -q "BEGIN CERTIFICATE" "$HISTORY/sstp/ca_$short_ip.crt" || ! sudo grep -q "END CERTIFICATE" "$HISTORY/sstp/ca_$short_ip.crt"; then
                    sudo rm -f "$HISTORY/sstp/ca_$short_ip.crt"
                    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: введенные данные не похожи на сертификат.${endc}" || echo -e "[*] ${rz}Error: input does not look like a certificate.${endc}"
                else
                    ca_opt="-ca \"ca_$short_ip.crt\""
                fi
                ;;
        esac
    done

    # Запускаем подключение с полученными параметрами
    if [ -z "$ca_opt" ]; then
        eval sudo sstpney on "$SERVERIP" "$SERVERLOGIN" "$SERVERPASS"
    else
        eval sudo sstpney on "$SERVERIP" "$SERVERLOGIN" "$SERVERPASS" $ca_opt
    fi
    exit $?
    ;;
    on|pon|start)
    # Проверяем наличие опции -ca
    ca_file=""
    for ((i=1; i<=$#; i++)); do
        if [ "${!i}" = "-ca" ]; then
            next=$((i+1))
            if [ $next -le $# ]; then
                ca_file="${!next}"
                # Удаляем -ca и имя файла из аргументов
                set -- "${@:1:i-1}" "${@:i+2}"
                break
            fi
        fi
    done

    if [ -z "$3" ] && [ -n "$2" ]; then
        # Если есть только один аргумент, обрабатываем его как строку с разделителями
        server_info="$2"
        # Разбиваем строку на части
        if [[ "$server_info" == *"|"* ]]; then
            # Разделитель - вертикальная черта
            IFS='|' read -r part1 part2 part3 <<< "$server_info"
        elif [[ "$server_info" == *":"* && "$server_info" != *" "* ]]; then
            # Разделитель - двоеточие
            # Специальная обработка для IP/Host:port
            if [[ "$server_info" =~ ^([^:]+:[0-9]+):([^:]+):([^:]+)$ ]]; then
                # Формат IP/Host:port:login:password
                part1=${BASH_REMATCH[1]}
                part2=${BASH_REMATCH[2]}
                part3=${BASH_REMATCH[3]}
            else
                IFS=':' read -r part1 part2 part3 <<< "$server_info"
            fi
        else
            # Предполагаем разделитель - пробел
            read -r part1 part2 part3 <<< "$server_info"
        fi

        # Определяем, что из частей является IP/Host и что логином/паролем
        if is_ip_or_host "$part1"; then
            # Формат: IP/Host логин пароль
            SERVERIP=$part1
            SERVERLOGIN=$part2
            SERVERPASS=$part3
        elif is_ip_or_host "$part3"; then
            # Формат: логин пароль IP/Host
            SERVERLOGIN=$part1
            SERVERPASS=$part2
            SERVERIP=$part3
        else
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось определить IP/Host в введенной строке.${endc}" || echo -e "[*] ${rz}Error: failed to determine IP/Host in the input string.${endc}"
            echo =================================
            exit 1
        fi
    else
        # Старый формат с тремя аргументами
        # Проверяем, какой из аргументов является IP/Host
        if is_ip_or_host "$4"; then
            SERVERIP="$4"
            SERVERLOGIN="$2"
            SERVERPASS="$3"
        elif is_ip_or_host "$2"; then
            SERVERIP="$2"
            SERVERLOGIN="$3"
            SERVERPASS="$4"
        else
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось определить IP/Host среди аргументов.${endc}" || echo -e "[*] ${rz}Error: failed to determine IP/Host among arguments.${endc}"
            echo =================================
            exit 1
        fi
    fi

    # Проверка наличия необходимых параметров
    if [ -z "$SERVERIP" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не указан IP/Host сервера.${endc}" || echo -e "[*] ${rz}Error: server IP/Host not specified.${endc}"
      echo =================================
      exit 1
    fi
    if [ -z "$SERVERLOGIN" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не указан логин.${endc}" || echo -e "[*] ${rz}Error: login not specified.${endc}"
      echo =================================
      exit 1
    fi
    if [ -z "$SERVERPASS" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не указан пароль.${endc}" || echo -e "[*] ${rz}Error: password not specified.${endc}"
      echo =================================
      exit 1
    fi
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Сервер IP/Host: ${zsh}$SERVERIP${endc}" || echo -e "[*] Server IP/Host: ${zsh}$SERVERIP${endc}"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Логин: ${zsh}$SERVERLOGIN${endc}" || echo -e "[*] Login: ${zsh}$SERVERLOGIN${endc}"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Пароль: ${zsh}$SERVERPASS${endc}" || echo -e "[*] Password: ${zsh}$SERVERPASS${endc}"

    # Обработка CA файла
    if [ -n "$ca_file" ]; then
        # Проверяем наличие файла в /home/ney
        if [ -f "/home/ney/$ca_file" ]; then
            sudo mkdir -p "$HISTORY/sstp"
            sudo mv "/home/ney/$ca_file" "$HISTORY/sstp"
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] CA: ${zsh}$ca_file${endc}" || echo -e "[*] CA: ${zsh}$ca_file${endc}"
        # Проверяем наличие файла в $HISTORY/sstp
        elif [ -f "$HISTORY/sstp/$ca_file" ]; then
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] CA: ${zsh}$ca_file${endc}" || echo -e "[*] CA: ${zsh}$ca_file${endc}"
        else
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: файл CA не найден.${endc}" || echo -e "[*] ${rz}Error: CA file not found.${endc}"
            echo =================================
            exit 1
        fi
        PTYCA="pty         \"sstpc $SERVERIP --ipparam ${0##*/} --save-server-route --nolaunchpppd --tls-ext --ca-cert $HISTORY/sstp/$ca_file\""
    else
        PTYCA="pty         \"sstpc $SERVERIP --ipparam ${0##*/} --save-server-route --nolaunchpppd --tls-ext\""
    fi

    echo [*]
    sudo ifconfig | egrep -o "ppp0" 1>/dev/null 2>&1
    if [ "$?" != "1" ]; then
      DELIP=$(route -n | grep UGH | awk '{print $1}') 1>/dev/null 2>&1
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Рестарт...${endc}" || echo -e "[*] ${yz}Restart...${endc}"
      sudo poff pptpney 1>/dev/null 2>&1
      sudo poff sstpney 1>/dev/null 2>&1
      sudo /usr/sbin/ipsec stop 1>/dev/null 2>&1
      sudo /etc/init.d/xl2tpd stop 1>/dev/null 2>&1
      sudo sh -c "echo 'd l2tpney' > /var/run/xl2tpd/l2tp-control" 1>/dev/null 2>&1
      sudo ipsec down l2tpney 1>/dev/null 2>&1
      sudo route delete $DELIP 1>/dev/null 2>&1
      sleep 1
      sudo killall -9 pppd 1>/dev/null 2>&1
      sleep 5
    fi
    sudo ifconfig vti0 1>/dev/null 2>&1
    if [ "$?" != "1" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Рестарт...${endc}" || echo -e "[*] ${yz}Restart...${endc}"
      sudo ikev2ney -s
      sleep 5
    fi
    [ "$LANGUAGE" = "RU" ] && echo -n "[*] Подключаемся к серверу по SSTP VPN." || echo -n "[*] Connecting to the server by SSTP VPN."
    
    sudo sh -c "echo $SERVERLOGIN sstpney \'$SERVERPASS\' \*> /etc/ppp/chap-secrets" 1>/dev/null 2>&1
    SSTP_CONF=/etc/ppp/peers/${0##*/}
cat > $SSTP_CONF <<EOF
remotename  ${0##*/}
linkname    ${0##*/}
ipparam     ${0##*/}
$PTYCA
name        $SERVERLOGIN
plugin      sstp-pppd-plugin.so
sstp-sock   /var/run/sstpc/sstpc-${0##*/}
usepeerdns
require-mschap-v2
refuse-eap
refuse-pap
refuse-chap
refuse-mschap
noauth
persist
maxfail 0
defaultroute
replacedefaultroute
EOF
    sudo pon ${0##*/} 1>/dev/null 2>&1
    i=0
    while [ $i -lt $TIME ];
    do
      sleep 1
      echo -n "."
      i=$(( $i + 1 ))
      result=$(ifconfig | grep -v ippp0 | grep ppp0 | awk '{print $1}')
      if ! test -z "$result" ; then
        echo
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Подключен к серверу по SSTP VPN." || echo -e "[*] ${gz}Done:${endc} Connected to the server by SSTP VPN."
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Время: `date +%T` `date +%d-%m-%Y`" || echo -e "[*] Time: `date +%T` `date +%d-%m-%Y`"
        echo -e "`date +%T`  `date +%d-%m-%Y`  VALID = sstpney $LASTCMD" >> $HISTORY/sstpney-h
        #echo [*] 'Отсоединить SSTP VPN-client - sudo sstpney -s'
        echo =================================
        break
      fi
    done
    if test -z "$result" ; then
      sudo poff ${0##*/} 1>/dev/null 2>&1
      sudo route delete $SERVERIP 1>/dev/null 2>&1
      sleep 1
      sudo killall -9 pppd 1>/dev/null 2>&1
      echo
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Информация: Не удалось подключиться к серверу по SSTP VPN.${endc}" || echo -e "[*] ${rz}Information: Failed to connect to the server by SSTP VPN.${endc}"
      echo -e "`date +%T`  `date +%d-%m-%Y`  NO VALID = sstpney $LASTCMD" >> $HISTORY/sstpney-h
      echo =================================
      exit 1
    fi
    shift
    exit 1 ;;
    -s|stop|off|poff)
    stop_sstpney
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} SSTP VPN-client отсоединен." || echo -e "[*] ${gz}Done:${endc} SSTP VPN-client disconnected."
    echo =================================
    shift
    exit 1 ;;
    enable)
    sudo systemctl enable sstpney.service 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Автоподключение SSTP VPN: ${zsh}включено${endc}" || echo -e "[*] ${gz}Done:${endc} Autostart SSTP VPN: ${zsh}enable${endc}"
    echo =================================
    shift
    exit 1 ;;
    disable)
    sudo systemctl disable sstpney.service 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Автоподключение SSTP VPN: ${zsh}отключено${endc}" || echo -e "[*] ${gz}Done:${endc} Autostart SSTP VPN: ${zsh}disable${endc}"
    echo =================================
    shift
    exit 1 ;;
    clear)
    sudo sed -i 'd' /etc/ppp/peers/sstpney 1>/dev/null 2>&1
    sudo rm -rf $HISTORY/sstp/* 1>/dev/null 2>&1
    sudo sh -c "echo > $HISTORY/sstpney-h 1>/dev/null 2>&1"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} История очищена." || echo -e "[*] ${gz}Done:${endc} History cleared."
    echo =================================
    shift
    exit 1
    ;;
    import)
    if [ ! "$(ls -A $HOMENEY/sstp-backup 2>/dev/null)" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось найти папку sstp-backup.${endc}" || echo -e "[*] ${rz}Error: failed to find sstp-backup directory.${endc}"
      echo =================================
      exit 1
    fi
    sudo cp -r $HOMENEY/sstp-backup/sstp $HISTORY/ 1>/dev/null 2>&1
    sudo cp $HOMENEY/sstp-backup/sstp-history $HISTORY/sstpney-h 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Импорт выполнен." || echo -e "[*] ${gz}Done:${endc} Import completed."
    echo =================================
    shift
    exit 1 ;;
    export)
    sudo mkdir -p $HOMENEY/sstp-backup 1>/dev/null 2>&1
    sudo cp -r $HISTORY/sstp $HOMENEY/sstp-backup/ 1>/dev/null 2>&1
    sudo cp $HISTORY/sstpney-h $HOMENEY/sstp-backup/sstp-history 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Экспорт выполнен. Папка sstp-backup в домашней папке." || echo -e "[*] ${gz}Done:${endc} Export completed. Directory sstp-backup in home directory."
    echo =================================
    shift
    exit 1 ;;
    *)
    if [ "$LANGUAGE" = "RU" ]; then
cat << EOF
[*] Использование: sudo sstpney [опции]
[*] Опции:
[*]  manager                             - менеджер SSTP VPN-клиент
[*]  on [IP/Host:port] [логин] [пароль] [-ca файл] - подключить. Если не указать порт, то
[*]                                          по умолчанию порт 443.
[*]  -s, stop, off, poff                 - отсоединить
[*]  enable                              - включить автоподключение при вкл малины
[*]  disable                             - выключить автоподключение при вкл малины
[*]  clear                               - очистить историю подключений
[*]  import                              - импортировать историю подключений
[*]  export                              - экспортировать историю подключений
[*]
[*] Контакт: телеграм @confxwho (никнейм: Ney)
EOF
    else
cat << EOF
[*] Usage: sudo sstpney [options]
[*] Options:
[*]  manager                               - SSTP VPN-client manager
[*]  on [IP/Host:port] [LOGIN] [PASSWORD] [-ca file] - connect. If not specify port, then
[*]                                            default port is 443.
[*]  -s, stop, off, poff                   - disconnect
[*]  enable                                - enable autostart on boot
[*]  disable                               - disable autostart on boot
[*]  clear                                 - clear connection history
[*]  import                                - import connection history
[*]  export                                - export connection history
[*]
[*] Contact: telegram @confxwho (nickname: Ney)
EOF
    fi
    echo =================================
    shift
    exit 1 ;;
esac
