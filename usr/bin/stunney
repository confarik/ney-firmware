#!/bin/bash
export LASTCMD=$@
# Загрузка настроек языка
LANGUAGE_CONFIG="/etc/language-ney.conf"
if [ -f "$LANGUAGE_CONFIG" ]; then
  source "$LANGUAGE_CONFIG"
else
  LANGUAGE="EN"
fi

# Установка локали в зависимости от выбранного языка
if [ "$LANGUAGE" = "RU" ]; then
  # Если выбран русский, проверяем наличие русской локали
  if locale -a 2>/dev/null | grep -q 'ru_RU.utf8\|ru_RU.UTF-8'; then
    export LC_ALL=ru_RU.UTF-8
    export LANG=ru_RU.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
else
  # Если выбран английский, используем английскую локаль
  if locale -a 2>/dev/null | grep -q 'en_US.utf8\|en_US.UTF-8'; then
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
fi
#######################################################################
#
#  /$$      /$$
# | $$$    /$$$
# | $$$$  /$$$$  /$$$$$$   /$$$$$$   /$$$$$$$
# | $$ $$/$$ $$ |____  $$ /$$__  $$ /$$_____/
# | $$  $$$| $$  /$$$$$$$| $$  \__/|  $$$$$$
# | $$\  $ | $$ /$$__  $$| $$       \____  $$
# | $$ \/  | $$|  $$$$$$$| $$       /$$$$$$$/
# |__/     |__/ \_______/|__/      |_______/
#
# Telegram: @confxwho
#######################################################################
rz='\033[1;31m' #'$rz'
mrz='\033[1;91m' #'$mrz'
gz='\033[1;32m' #'$gz'
yz='\033[1;33m' #'$yz'
myz='\033[1;93m' #'$myz'
skyz='\033[1;36m' #'$skyz'
bz='\033[44;37m' #'$bz'
zsh='\033[1m' #'$zsh'
blink='\033[5;33m' # Мигающий желтый текст
endc='\033[0m' #'$endc'

QUIET_MODE=false
if [ "$1" = "-q" ]; then
  QUIET_MODE=true
  shift
fi

if ! $QUIET_MODE; then
echo -e ========='|'$bz' StunNey 2.0 '$endc'|'========
fi

if [ "$LANGUAGE" = "RU" ]; then
    CONTACT="[*] ${skyz}Телеграм${endc} контакт: ${yz}@confxwho${endc}
[*]          канал: ${yz}@confxwho${endc}"
else
    CONTACT="[*] ${skyz}Telegram${endc} contact: ${yz}@confxwho${endc}
[*]          channel: ${yz}@confxwho${endc}"
fi
SERIALNEYPI=$(grep -oP 'Serial\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
REVISIONNEYPI=$(grep -oP 'Revision\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
SERIAL_FILE="/etc/security/${SERIALNEYPI}"
if [[ $SERIALNEYPI != a6bb65ad2ae10c15 ]] || [[ $REVISIONNEYPI != b04171 ]] || \
   [[ ! -f "$SERIAL_FILE" ]] || [[ "$(cat "$SERIAL_FILE" 2>/dev/null)" != "$SERIALNEYPI" ]]; then
     echo -e "$CONTACT"
     echo =================================
     exit 1
fi

sudo which stunnel4 1>/dev/null ||
{ echo -e [*] ''$yz'You must install Stunnel.'$endc'' ; exit 1 ; }

HOMENEY=/home/ney
DIRSTUN=/etc/stunnel
HISTORY=/etc/history-vpn-proxy

case $1 in
    manager)
    STUN_STATUS=""
    if sudo ss -tlpn 2>/dev/null | grep -q stunnel4; then
      STUN_STATUS=$(
[ "$LANGUAGE" = "RU" ] && echo "[*] Stunnel-клиент: ВКЛ" || echo "[*] Stunnel-client: ON"
[ "$LANGUAGE" = "RU" ] && echo "[*]  Сервер IP/Host: $(sudo grep -oP '^connect\s*=\s*\K.*' /etc/stunnel/stunnel.conf 2>/dev/null)" || echo "[*]  Server IP/Host: $(sudo grep -oP '^connect\s*=\s*\K.*' /etc/stunnel/stunnel.conf 2>/dev/null)"
      )
    else
      [ "$LANGUAGE" = "RU" ] && STUN_STATUS="[*] Stunnel-клиент: ВЫКЛ" || STUN_STATUS="[*] Stunnel-client: OFF"
    fi
    
    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
$STUN_STATUS

enter: запустить
n: запустить новый конфиг
s: остановить
e: редактировать конфиг
a: включить автозапуск
d: выключить автозапуск
h: история запуска
delete: удалить конфиг
ctrl-i: импортировать все конфиги
ctrl-e: экспортировать все конфиги
ESC: выйти"
        EXIT_MSG="Для выхода нажмите любую клавишу"
        BORDER_LABEL="| Менеджер Stunnel-клиент |"
    else
      FZF_HEADER="
$STUN_STATUS

enter: start
n: start new config
s: stop
e: edit config
a: enable autostart
d: disable autostart
h: startup history
delete: delete config
ctrl-i: import all configs
ctrl-e: export all configs
ESC: exit"
        EXIT_MSG="Press any key to exit"
        BORDER_LABEL="| Stunnel-client manager |"
    fi

    (for CONFIG in $(ls $DIRSTUN/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do
        if [ "$CONFIG" != "stunnel.conf" ]; then
            if systemctl is-enabled stunnel4 &>/dev/null && [ -f "$DIRSTUN/stunnel.conf" ] && diff -q "$DIRSTUN/$CONFIG" "$DIRSTUN/stunnel.conf" &>/dev/null; then
                echo -e "$CONFIG $bz(auto)$endc"
            else
                echo "$CONFIG"
            fi
        else
            echo "$CONFIG"
        fi
    done) | fzf --ansi --style default  --preview 'cat -n /etc/stunnel/$(echo {} | cut -d" " -f1)' \
      --header="$FZF_HEADER" \
      --bind='n:execute(stunney -q start; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(stunney -q manager)' \
      --bind='enter:execute(stunney -q start $(echo {} | cut -d" " -f1); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(stunney -q manager)' \
      --bind='s:execute-silent(sudo stunney stop && sleep 1)+become(stunney -q manager)' \
      --bind='e:execute(sudo nano -l -m /etc/stunnel/$(echo {} | cut -d" " -f1))' \
      --bind='e:+reload(for CONFIG in $(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "stunnel.conf" ]; then if systemctl is-enabled stunnel4 &>/dev/null && [ -f "/etc/stunnel/stunnel.conf" ] && diff -q "/etc/stunnel/$CONFIG" "/etc/stunnel/stunnel.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='a:execute-silent(sudo stunney enable $(echo {} | cut -d" " -f1))' \
      --bind='a:+reload(for CONFIG in $(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "stunnel.conf" ]; then if systemctl is-enabled stunnel4 &>/dev/null && [ -f "/etc/stunnel/stunnel.conf" ] && diff -q "/etc/stunnel/$CONFIG" "/etc/stunnel/stunnel.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='d:execute-silent(sudo stunney disable)' \
      --bind='d:+reload(for CONFIG in $(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "stunnel.conf" ]; then if systemctl is-enabled stunnel4 &>/dev/null && [ -f "/etc/stunnel/stunnel.conf" ] && diff -q "/etc/stunnel/$CONFIG" "/etc/stunnel/stunnel.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='h:execute(stunney -q history; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(stunney -q manager)' \
      --bind='delete:execute-silent(sudo stunney -rm $(echo {} | cut -d" " -f1))' \
      --bind='delete:+reload(for CONFIG in $(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "stunnel.conf" ]; then if systemctl is-enabled stunnel4 &>/dev/null && [ -f "/etc/stunnel/stunnel.conf" ] && diff -q "/etc/stunnel/$CONFIG" "/etc/stunnel/stunnel.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
      --bind='ctrl-i:execute(sudo stunney -q import; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+become(stunney -q manager)' \
      --bind='ctrl-e:execute(sudo stunney -q export; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+reload(stunney -q manager)' \
      --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
      --height=65% --info=inline --margin=1 --padding=1
    if ! $QUIET_MODE; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
      echo =================================
    fi
    shift
    exit 1 ;;
    up|start)
    configstun="$2"
    if [ -f "$HOMENEY/$configstun" ]; then
      stunbezconf=$(sudo ls $configstun | cut -d/ -f4 | sed 's/.conf$//')
      sudo mv $stunbezconf* $DIRSTUN/
      sudo chmod 644 $DIRSTUN/$configstun
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Файлы conf/cert/pem Stunnel ${zsh}$stunbezconf${endc} уже перемещены в папку $DIRSTUN" || echo -e "[*] ${gz}Done:${endc} Files conf/cert/pem Stunnel ${zsh}$stunbezconf${endc} moved to $DIRSTUN"
    fi
    if [ -n "$configstun" ]; then
      sudo cp $DIRSTUN/$configstun $DIRSTUN/stunnel.conf
      sudo chmod 644 $DIRSTUN/stunnel.conf
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выбран конфиг Stunnel ${zsh}$configstun${endc}" || echo -e "[*] Selected config Stunnel ${zsh}$configstun${endc}"
      constun=$(sudo netstat -tlpn | grep stunnel4)
      if ! test -z "$constun" ; then
        [ "$LANGUAGE" = "RU" ] && echo -e $yz"[*] Рестарт..."$endc || echo -e $yz"[*] Restarting..."$endc
        sudo killall stunnel4 1>/dev/null 2>&1
        sleep 1
      fi

      stunname=$(sudo cat $DIRSTUN/stunnel.conf | grep connect | cut -d= -f2)
      sudo nohup stunnel4 $DIRSTUN/stunnel.conf 1>/dev/null 2>&1
      sleep 3
      constun=$(sudo netstat -tlpn | grep stunnel4)
      if ! test -z "$constun" ; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Запущен Stunnel: ${zsh}$stunname${endc}" || echo -e "[*] ${gz}Done:${endc} Stunnel: ${zsh}$stunname${endc} started"
        echo -e "`date +%T`  `date +%d-%m-%Y`  VALID = stunney $LASTCMD" | sed 's/ -q//' >> $HISTORY/stunney-h
      fi
      if test -z "$constun" ; then
        sudo killall stunnel4 1>/dev/null 2>&1
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Информация: не удалось запустить Stunnel.$endc" || echo -e "[*] ${rz}Information: failed to start Stunnel.$endc"
        echo -e "`date +%T`  `date +%d-%m-%Y`  NO VALID = stunney $LASTCMD" | sed 's/ -q//' >> $HISTORY/stunney-h
      fi
      echo =================================
    else
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: запустить новый конфиг
ESC: выход"
        BORDER_LABEL="| Менеджер Stunnel-клиент |"
      else
        FZF_HEADER="
enter: start new config
ESC: exit"
        BORDER_LABEL="| Stunnel-client manager |"
      fi
      configstun=$(ls -l $HOMENEY/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r | fzf --ansi --style default --preview 'cat -n /home/ney/{}' \
        --header="$FZF_HEADER" \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$configstun" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      else
        sudo stunney start $configstun
      fi
    fi
    shift
    exit 1 ;;
    stop|-s)
    sudo killall stunnel4 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Остановлен Stunnel-клиент." || echo -e "[*] ${gz}Done:${endc} Stunnel-client stopped."
    echo =================================
    shift
    exit 1 ;;
    enable)
    configstun="$2"
    if [ ! -f "$DIRSTUN/$configstun" ]; then
      configstun=$(
      (for CONFIG in $(ls $DIRSTUN/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do
        if [ "$CONFIG" != "stunnel.conf" ]; then
            if systemctl is-enabled stunnel4 &>/dev/null && [ -f "$DIRSTUN/stunnel.conf" ] && diff -q "$DIRSTUN/$CONFIG" "$DIRSTUN/stunnel.conf" &>/dev/null; then
                echo -e "$CONFIG $bz(auto)$endc"
            else
                echo "$CONFIG"
            fi
        else
            echo "$CONFIG"
        fi
        if [ "$LANGUAGE" = "RU" ]; then
            FZF_HEADER="
enter: выбрать для автозапуска
d: отключить автозапуск
ESC: выход"
            BORDER_LABEL="| Менеджер Stunnel-клиент |"
        else
            FZF_HEADER="
enter: select for autostart
d: disable auto
ESC: exit"
            BORDER_LABEL="| Stunnel-client manager |"
        fi
      done) | fzf --ansi --style default  --preview 'cat -n /etc/stunnel/$(echo {} | cut -d" " -f1)' \
        --header="$FZF_HEADER" \
        --bind='enter:execute-silent(sudo stunney enable $(echo {} | cut -d" " -f1))' \
        --bind='enter:+reload(for CONFIG in $(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "stunnel.conf" ]; then if systemctl is-enabled stunnel4 &>/dev/null && [ -f "/etc/stunnel/stunnel.conf" ] && diff -q "/etc/stunnel/$CONFIG" "/etc/stunnel/stunnel.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
        --bind='d:execute-silent(sudo stunney disable)' \
        --bind='d:+reload(for CONFIG in $(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r); do if [ "$CONFIG" != "stunnel.conf" ]; then if systemctl is-enabled stunnel4 &>/dev/null && [ -f "/etc/stunnel/stunnel.conf" ] && diff -q "/etc/stunnel/$CONFIG" "/etc/stunnel/stunnel.conf" &>/dev/null; then echo -e "$CONFIG \033[44;37m(auto)\033[0m"; else echo "$CONFIG"; fi; else echo "$CONFIG"; fi; done)' \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$configstun" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      fi
    fi
    sudo cp $DIRSTUN/$configstun $DIRSTUN/stunnel.conf
    sudo chmod 644 $DIRSTUN/stunnel.conf
    sudo systemctl enable stunnel4 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} При вкл малины конфиг Stunnel ${zsh}$configstun${endc} автоматически запускается." || echo -e "[*] ${gz}Done:${endc} Config Stunnel ${zsh}$configstun${endc} enabled on boot."
    echo =================================
    shift
    exit 1 ;;
    disable)
    sudo systemctl disable stunnel4 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Отключен автозапуск Stunnel при вкл малины." || echo -e "[*] ${gz}Done:${endc} Disabled autostart Stunnel on boot."
    echo =================================
    shift
    exit 1 ;;
    -ls)
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${zsh}Список конфигов Stunnel:${endc}" || echo -e "[*] ${zsh}List of Stunnel configs:${endc}"
    sudo ls -1 $DIRSTUN/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev
    echo =================================
    shift
    exit 1 ;;
    -mv)
    configstun="$2"
    if [ ! -f "$HOMENEY/$configstun" ]; then

      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: переместить конфиг в /etc/stunnel
ESC: выход"
        BORDER_LABEL="| Менеджер Stunnel-клиент |"
      else
        FZF_HEADER="
enter: move config to /etc/stunnel
ESC: exit"
        BORDER_LABEL="| Stunnel-client manager |"
      fi

      (ls -l $HOMENEY/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r) | fzf --ansi --style default --preview 'cat -n /home/ney/{}' \
        --header="$FZF_HEADER" \
        --bind='enter:execute-silent(sudo stunney -mv {})' \
        --bind='enter:+reload(ls /home/ney/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r)' \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1
      if [ -z "$configstun" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      fi
    else
      stunbezconf=$(sudo ls $configstun | cut -d/ -f4 | sed 's/.conf$//')
      sudo mv $stunbezconf* $DIRSTUN/
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Файлы conf/cert/pem Stunnel ${zsh}$stunbezconf${endc} уже перемещены в папку $DIRSTUN" || echo -e "[*] ${gz}Done:${endc} Files conf/cert/pem Stunnel ${zsh}$stunbezconf${endc} moved to $DIRSTUN"
    fi
    echo =================================
    shift
    exit 1 ;;
    -rm)
    configstun="$2"
    if [ ! -f "$DIRSTUN/$configstun" ]; then
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: удалить конфиг
a: удалить все конфиги
ESC: выход"
        BORDER_LABEL="| Менеджер Stunnel-клиент |"
      else
        FZF_HEADER="
enter: delete conf
a: delete all confs
ESC: exit"
        BORDER_LABEL="| Stunnel-client manager |"
      fi
      (ls $DIRSTUN/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r) | fzf --ansi --style default --preview 'cat -n /etc/stunnel/{}' \
        --header="$FZF_HEADER" \
        --bind='enter:execute-silent(sudo stunney -rm {})' \
        --bind='enter:+reload(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r)' \
        --bind='a:execute-silent(sudo stunney -rm-all)' \
        --bind='a:+reload(ls /etc/stunnel/*.conf 2>/dev/null | rev | cut -d/ -f1 | rev | sort -r)' \
        --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
        --height=40% --info=inline --margin=1 --padding=1
      if [ -z "$configstun" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 1
      fi
    else
      stunbezconf=$(sudo ls $DIRSTUN/$configstun | cut -d/ -f4 | sed 's/.conf$//')
      sudo rm -rf $DIRSTUN/{"$configstun","$stunbezconf.cert","$stunbezconf.pem"} 1>/dev/null 2>&1
      sudo touch $DIRSTUN/stunnel.conf 1>/dev/null 2>&1
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Удален конфиг Stunnel ${zsh}$configstun${endc}" || echo -e "[*] ${gz}Done:${endc} Config Stunnel ${zsh}$configstun${endc} deleted."
    fi
    echo =================================
    shift
    exit 1 ;;
    -rm-all)
    sudo rm -rf $DIRSTUN/* 1>/dev/null 2>&1
    sudo touch $DIRSTUN/stunnel.conf 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Удалены все конфиги Stunnel" || echo -e "[*] ${gz}Done:${endc} All Stunnel configs deleted."
    echo =================================
    shift
    exit 1 ;;
    history)
    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
enter: запустить
a: очистить историю запуска
ESC: выход"
    else
      FZF_HEADER="
enter: start
a: clear startup history
ESC: exit"
    fi
    HISTORYSTUN=$(cat $HISTORY/stunney-h 2>/dev/null | sort -r -k2,2 | sed "s/NO VALID/$(echo -e "$rz")NO VALID$(echo -e "$endc")/g" | sed "s/  VALID/$(echo -e "$gz")  VALID$(echo -e "$endc")/g" | fzf --ansi \
      --header="$FZF_HEADER" \
      --bind='a:become(echo > /etc/history-vpn-proxy/stunney-h 1>/dev/null 2>&1)' \
      --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
      --height=40% --info=inline --margin=1 --padding=1)
    if [ -z "$HISTORYSTUN" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
      echo =================================
      exit 1
    fi
    TUSTUN=$(echo "$HISTORYSTUN" | cut -d= -f2)
    echo 'sudo'$TUSTUN''
    sudo $TUSTUN
    shift
    exit 1 ;;
    clear)
    sudo sh -c "echo > $HISTORY/stunney-h 1>/dev/null 2>&1"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} История очищена." || echo -e "[*] ${gz}Done:${endc} History cleared."
    echo =================================
    shift
    exit 1 ;;
    import)
    if [ ! "$(ls -A $HOMENEY/stunnel-backup/* 2>/dev/null)" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось найти папку stunnel-backup.${endc}" || echo -e "[*] ${rz}Failed: stunnel-backup directory not found.${endc}"
      echo =================================
      exit 1
    fi
    sudo cp $HOMENEY/stunnel-backup/* $DIRSTUN 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Импорт выполнен." || echo -e "[*] ${gz}Done:${endc} Import completed."
    echo =================================
    shift
    exit 1 ;;
    export)
    sudo mkdir -p $HOMENEY/stunnel-backup 1>/dev/null 2>&1
    sudo cp $DIRSTUN/* $HOMENEY/stunnel-backup 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Экспорт выполнен. Папка stunnel-backup в домашней папке." || echo -e "[*] ${gz}Done:${endc} Export completed. stunnel-backup directory in home directory."
    echo =================================
    shift
    exit 1 ;;
    *)
    if [ "$LANGUAGE" = "RU" ]; then
cat << EOF
[*] Использование: sudo stunney [опции]
[*] Опции:
[*]  manager           - менеджер Stunnel-клиент
[*]  start [конфиг]    - запустить новый (можно не ввести конфиг)
[*]  stop              - отключить
[*]  enable            - включить автозапуск при вкл малины
[*]  disable           - отключить автозапуск при вкл малины
[*]  -ls               - cписок конфигов
[*]  -mv [конфиг]      - переместить файл conf/cert/pem в /etc/stunnel (можно не ввести конфиг)
[*]  -rm [конфиг]      - удалить конфиг (можно не ввести конфиг)
[*]  -rm-all           - удалить все конфиги
[*]  history           - история запуска
[*]  clear             - очистить историю
[*]  import            - импортировать все конфиги в /etc/stunnel
[*]  export            - экспортировать все конфиги в домашнюю папку
[*]
[*]   Как скинуть конфиг Stunnel на малину и запустить:
[*]   1. В конфиге stunnel нужно указать путь к файлу crt или pem. Открыть конфиг stunnel,
[*]      найти строку CAfile = stunnel.crt или cert = stunnel.pem и
[*]      добавить без пробела /etc/stunnel/ перед stunnel.crt или stunnel.pem,
[*]      то есть вот так /etc/stunnel/stunnel.crt.
[*]   2. Скинуть конфиг и файл crt или pem на малину в домашнюю
[*]      папку /home/pi через SFTP(есть в битваисе кнопка "New SFTP window" в левой колонне,
[*]      а для MacOS бесплатая программа ForkLift) или SCP.
[*]   3. Переместить файл crt или pem в папку для Stunnel: sudo stunney -mv [файл]
[*]
[*] Контакт: телеграм @confxwho (никнейм: Ney)
EOF
    else
cat << EOF
[*] Usage: sudo stunney [options]
[*] Options:
[*]  manager           - Stunnel-client manager
[*]  start [config]    - start new
[*]  stop              - stop
[*]  enable            - enable autostart on boot
[*]  disable           - disable autostart on boot
[*]  -ls               - list configs
[*]  -mv [config]      - move file conf/cert/pem to /etc/stunnel (can don't have to enter config)
[*]  -rm [config]      - remove config (can don't have to enter config)
[*]  -rm-all           - remove all configs
[*]  history           - history of starts
[*]  clear             - clear history
[*]  import            - import all configs to /etc/stunnel
[*]  export            - export all configs to home directory
[*]
[*]   How to send Stunnel config to Raspberry Pi and start:
[*]   1. In the stunnel config, specify the path to the crt or pem file. Open the stunnel config,
[*]      find the line CAfile = stunnel.crt or cert = stunnel.pem and
[*]      add /etc/stunnel/ before stunnel.crt or stunnel.pem,
[*]      so it looks like /etc/stunnel/stunnel.crt.
[*]   2. Send the config and crt or pem file to the Raspberry Pi's home directory
[*]      /home/pi through SFTP(there is a button "New SFTP window" in the left column in Bitvise,
[*]      or a free program ForkLift for MacOS) or SCP.
[*]   3. Move the crt or pem file to the Stunnel directory: sudo stunney -mv [file]
[*]
[*] Contact: telegram @confxwho (nickname: Ney)
EOF
    fi
    echo =================================
    shift
    exit 1 ;;
esac
