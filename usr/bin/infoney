#!/bin/bash

# Загрузка настроек языка
LANGUAGE_CONFIG="/etc/language-ney.conf"
if [ -f "$LANGUAGE_CONFIG" ]; then
  source "$LANGUAGE_CONFIG"
else
  LANGUAGE="EN"
fi

# Установка локали в зависимости от выбранного языка
if [ "$LANGUAGE" = "RU" ]; then
  # Если выбран русский, проверяем наличие русской локали
  if locale -a 2>/dev/null | grep -q 'ru_RU.utf8\|ru_RU.UTF-8'; then
    export LC_ALL=ru_RU.UTF-8
    export LANG=ru_RU.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
else
  # Если выбран английский, используем английскую локаль
  if locale -a 2>/dev/null | grep -q 'en_US.utf8\|en_US.UTF-8'; then
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
fi
#######################################################################
#
#  /$$      /$$
# | $$$    /$$$
# | $$$$  /$$$$  /$$$$$$   /$$$$$$   /$$$$$$$
# | $$ $$/$$ $$ |____  $$ /$$__  $$ /$$_____/
# | $$  $$$| $$  /$$$$$$$| $$  \__/|  $$$$$$
# | $$\  $ | $$ /$$__  $$| $$       \____  $$
# | $$ \/  | $$|  $$$$$$$| $$       /$$$$$$$/
# |__/     |__/ \_______/|__/      |_______/
#
# Telegram: @confxwho
#######################################################################
rz='\033[1;31m' #'$rz'
mrz='\033[1;91m' #'$mrz'
gz='\033[1;32m' #'$gz'
yz='\033[1;33m' #'$yz'
myz='\033[1;93m' #'$myz'
skyz='\033[1;36m' #'$skyz'
bz='\033[44;37m' #'$bz'
zsh='\033[1m' #'$zsh'
blink='\033[5;33m' # Мигающий желтый текст
endc='\033[0m' #'$endc'
KT=$(echo -e '[\033[2;31m*\033[0m]')
KTS=$(echo -e '[\033[1;96m>\033[0m]')

QUIET_MODE=false
if [ "$1" = "-q" ]; then
  QUIET_MODE=true
  shift
fi

if ! $QUIET_MODE; then
echo -e ========'|'$bz' InfoNey 3.0 '$endc'|'=========
fi

check_internet() {
    checkppp0vti0=$(ip route show | grep "default" | egrep -o -a "ppp0|ppp1|vti0")
    if [ -n "$checkppp0vti0" ]; then
      interdef=$checkppp0vti0
    else
      interdef=$(ip route show | grep "default" | awk '{print $5}' | sed 1q)
    fi
    interip=$(ifconfig $interdef | grep "inet " | awk '{print $2}' | cut -d/ -f1)
    ping -c 1 -W 2 $interip >/dev/null 2>&1 ||
    ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1 ||
    ping -c 1 -W 2 1.1.1.1 >/dev/null 2>&1 ||
    curl -s -m 3 --retry 2 https://cloudflare.com/cdn-cgi/trace >/dev/null 2>&1 ||
    curl -s -m 3 --retry 2 https://www.google.com >/dev/null 2>&1
    return $?
}
get_public_ipv4() {
    public_ipv4=$(curl -s -4 -m 3 https://api.ipify.org 2>/dev/null) ||
    public_ipv4=$(curl -s -4 -m 3 https://ifconfig.me 2>/dev/null) ||
    public_ipv4=$(curl -s -4 -m 3 https://icanhazip.com 2>/dev/null) ||
    public_ipv4=$(curl -s -4 -m 3 https://v4.ident.me 2>/dev/null) ||
    public_ipv4="N/A"
    echo "$public_ipv4"
}
get_public_ipv6() {
    public_ipv6=$(curl -s -6 -m 3 https://api6.ipify.org 2>/dev/null) ||
    public_ipv6=$(curl -s -6 -m 3 https://ifconfig.co 2>/dev/null) ||
    public_ipv6=$(curl -s -6 -m 3 https://v6.ident.me 2>/dev/null) ||
    public_ipv6=$(curl -s -6 -m 3 ifconfig.me 2>/dev/null) ||
    public_ipv6="N/A"
    echo "$public_ipv6"
}

    echo -e $KT' '$(grep "Model" /proc/cpuinfo | cut -d: -f2 | xargs)' (CPU: '$zsh''$(vcgencmd measure_temp 2>/dev/null | cut -d= -f2)''$endc')'
# Вывод информации в зависимости от выбранного языка
if [ "$LANGUAGE" = "RU" ]; then
    # Русский вывод
    echo -e $KT' Ревизия: '$zsh''$(grep -oP 'Revision\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)''$endc' Сер. номер: '$zsh''$(grep -oP 'Serial\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)''$endc''
    echo -e $KT' Kernel версия: '$zsh''$(uname -r 2>/dev/null)''$endc''
    echo -e $KT' Linux Ney версия: '$zsh''$(grep "Linux Ney" /etc/motd 2>/dev/null | awk '{print $4" "$5}')''$endc''
    echo -e "$KTS Время: `date`"
else
    # Английский вывод
    echo -e $KT' Revision: '$zsh''$(grep -oP 'Revision\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)''$endc' Serial: '$zsh''$(grep -oP 'Serial\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)''$endc''
    echo -e $KT' Kernel version: '$zsh''$(uname -r 2>/dev/null)''$endc''
    echo -e $KT' Linux Ney version: '$zsh''$(grep "Linux Ney" /etc/motd 2>/dev/null | awk '{print $4" "$5}')''$endc''
    echo -e "$KTS Time: `date`"
fi

if [ "$LANGUAGE" = "RU" ]; then
    CONTACT="$KT
$KT ${skyz}Телеграм${endc} контакт: ${yz}@confxwho${endc}
$KT          канал: ${yz}@confxwho${endc}"
else
    CONTACT="$KT
$KT ${skyz}Telegram${endc} contact: ${yz}@confxwho${endc}
$KT          channel: ${yz}@confxwho${endc}"
fi

echo

[ "$LANGUAGE" = "RU" ] && echo -e -n $KTS' '$zsh'Интернет (WAN): '$endc'' || echo -e -n $KTS' '$zsh'Internet (WAN): '$endc''
if check_internet; then
  checkppp0vti0=$(ip route show | grep "default" | egrep -o -a "ppp0|ppp1|vti0")
  if [ -n "$checkppp0vti0" ]; then
    interdef=$checkppp0vti0
  else
    interdef=$(ip route show | grep "default" | awk '{print $5}' | sed 1q)
  fi
  [ "$LANGUAGE" = "RU" ] && echo -e ''$gz'онлайн'$endc' ('$interdef')' || echo -e ''$gz'online'$endc' ('$interdef')'
  interip=$(ifconfig $interdef | grep "inet " | awk '{print $2}' | cut -d/ -f1)
  [ "$LANGUAGE" = "RU" ] && echo -e $KT'  Локальный IPv4: '$zsh''$interip''$endc'' || echo -e $KT'  Local IPv4: '$zsh''$interip''$endc''
  publicip=$(get_public_ipv4)
  [ "$LANGUAGE" = "RU" ] && echo -e $KTS'  Внешний IPv4: '$zsh''$publicip''$endc'' || echo -e $KTS'  Public IPv4: '$zsh''$publicip''$endc''
  interip6=$(ifconfig $interdef | grep "scopeid 0x20<link>" | awk '{print $2}' | cut -d/ -f1)
  if [ -n "$interip6" ]; then
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS'  Локальный IPv6: '$zsh''$interip6''$endc'' || echo -e $KTS'  Local IPv6: '$zsh''$interip6''$endc''
    publicip6=$(get_public_ipv6)
    if [ -n "$publicip6" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e $KTS'  Внешний IPv6: '$zsh''$publicip6''$endc'' || echo -e $KTS'  Public IPv6: '$zsh''$publicip6''$endc''
    else
      [ "$LANGUAGE" = "RU" ] && echo -e $KT'  Внешний IPv6: '$zsh'N/A'$endc'' || echo -e $KT'  Public IPv6: '$zsh'N/A'$endc''
    fi
  else
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS'  IPv6: '$rz'ВЫКЛ'$endc'' || echo -e $KTS'  IPv6: '$rz'OFF'$endc''
  fi
else
  [ "$LANGUAGE" = "RU" ] && echo -e ''$rz'оффлайн'$endc'' || echo -e ''$rz'offline'$endc''
fi
echo -e -n $KTS' '$zsh'DNS1: '$endc''
DNSIP1=$(sudo cat /etc/resolv.conf | grep -E -ao "([0-9]{1,3}[\.]){3}[0-9]{1,3}|(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]).){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]).){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))" | sed -n '1p')
echo -n "$(if [ -n "$DNSIP1" ]; then echo $DNSIP1; else echo -n 'N/A'; fi)"
echo -e -n ''$zsh' DNS2: '$endc''
DNSIP2=$(sudo cat /etc/resolv.conf | grep -E -ao "([0-9]{1,3}[\.]){3}[0-9]{1,3}|(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]).){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]).){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))" | sed -n '2p')
echo -n "$(if [ -n "$DNSIP2" ]; then echo $DNSIP2; else echo -n 'N/A'; fi)"
# Проверка наличия DNS3 и вывод только если он существует
DNSIP3=$(sudo cat /etc/resolv.conf | grep -E -ao "([0-9]{1,3}[\.]){3}[0-9]{1,3}|(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]).){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]).){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))" | sed -n '3p')
if [ -n "$DNSIP3" ]; then
  echo -e -n ''$zsh' DNS3: '$endc''
  echo "$DNSIP3"
else
  echo
fi
[ "$LANGUAGE" = "RU" ] && echo -e $KTS' '$zsh'Килл-свич VPN/Proxy: '$endc''$(sudo iptables -nvL 2>/dev/null | grep -qE "tun+|tap+|vti0|ppp0|ppp1|wg0|wg1|pr0|ss0|ssh0" && echo -e ''$gz'ВКЛ'$endc'' || echo -e ''$rz'ВЫКЛ'$endc'')
[ "$LANGUAGE" = "EN" ] && echo -e $KTS' '$zsh'Kill-Switch VPN/Proxy: '$endc''$(sudo iptables -nvL 2>/dev/null | grep -qE "tun+|tap+|vti0|ppp0|ppp1|wg0|wg1|pr0|ss0|ssh0" && echo -e ''$gz'ON'$endc'' || echo -e ''$rz'OFF'$endc'')



echo
[ "$LANGUAGE" = "RU" ] && echo -e -n $KTS' '$zsh'WiFi-WLAN (Интернет): '$endc'' || echo -e -n $KTS' '$zsh'WiFi-WLAN (Internet): '$endc''
conwpa=$(sudo iwgetid | grep -c "ESSID:")
if [ $conwpa -eq 1 ]; then
  interfacewlan=$(sudo iwgetid | awk '{print $1}')
  frequency=$(sudo iwconfig $interfacewlan | grep "Frequency:" | awk '{print $2}' | cut -d: -f2)
  namessid=$(sudo iwconfig $interfacewlan | grep "ESSID:" | cut -d: -f2 | awk '{print $1}' | sed 's/\"//g')
  [ "$LANGUAGE" = "RU" ] && echo -e ''$gz'подключено'$endc' ('$interfacewlan', '$frequency' GHz)' || echo -e ''$gz'connected'$endc' ('$interfacewlan', '$frequency' GHz)'
  echo -n $KT'  '
  nmcli -f BSSID,SSID,SIGNAL,BARS,CHAN,RATE dev wifi list | head -n 1
  echo -n $KT'  '
  nmcli -f BSSID,SSID,SIGNAL,BARS,CHAN,RATE dev wifi list | egrep "$namessid" | awk '!seen[$1]++' 
else
  [ "$LANGUAGE" = "RU" ] && echo -e ''$rz'не подключено'$endc'' || echo -e ''$rz'not connected'$endc''
  #echo -n $KT'  '
  #nmcli -f BSSID,SSID,SIGNAL,BARS,SECURITY,CHAN,RATE dev wifi list | head -n 1
  #echo $KT'                     N/A'
fi

echo

check_pi_for_lan=$(sudo cat /proc/device-tree/model| egrep -ao "Raspberry Pi Zero W Rev 1.1|Raspberry Pi Zero 2 W Rev 1.0")
FOLDERNM=/etc/NetworkManager/system-connections
if [ -n "$check_pi_for_lan" ]; then
  if ip link show eth0 >/dev/null 2>&1; then
    [ "$LANGUAGE" = "RU" ] && echo -e -n $KTS' '$zsh'USB-LAN/модем (eth0): '$endc''$(test -f "$FOLDERNM/LAN-OUT.nmconnection" 2>/dev/null && echo 'OUT (для LAN)' || echo 'IN (для WAN)')
    [ "$LANGUAGE" = "EN" ] && echo -e -n $KTS' '$zsh'USB-LAN/modem (eth0): '$endc''$(test -f "$FOLDERNM/LAN-OUT.nmconnection" 2>/dev/null && echo 'OUT (for LAN)' || echo 'IN (for WAN)')
  else
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS' '$zsh'USB-LAN/модем (eth0):'$endc' '$yz'(адаптер USB-LAN/модем отсутствует)'$endc'' || echo -e $KTS' '$zsh'USB-LAN/modem (eth0):'$endc' '$yz'(adapter USB-LAN/modem is not present)'$endc''
  fi
else
  if ip link show eth0 >/dev/null 2>&1; then
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS' '$zsh'LAN-порт (eth0):'$endc' LAN-'$(test -f "$FOLDERNM/LAN-OUT.nmconnection" 2>/dev/null && echo "OUT (для LAN)" || echo "IN (для WAN)")
    [ "$LANGUAGE" = "EN" ] && echo -e $KTS' '$zsh'LAN-port (eth0):'$endc' LAN-'$(test -f "$FOLDERNM/LAN-OUT.nmconnection" 2>/dev/null && echo "OUT (for LAN)" || echo "IN (for WAN)")
  fi
  if ip link show eth1 >/dev/null 2>&1; then
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS' '$zsh'USB (eth1):'$endc' модем/LAN2-'$(test -f "$FOLDERNM/LAN2-OUT.nmconnection" 2>/dev/null && echo "OUT (для LAN)" || echo "IN (для WAN)")
    [ "$LANGUAGE" = "EN" ] && echo -e $KTS' '$zsh'USB (eth1):'$endc' modem/LAN2-'$(test -f "$FOLDERNM/LAN2-OUT.nmconnection" 2>/dev/null && echo "OUT (for LAN)" || echo "IN (for WAN)")
  fi
  if ip link show eth2 >/dev/null 2>&1; then
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS' '$zsh'USB (eth2):'$endc' LAN3-'$(test -f "$FOLDERNM/LAN3-OUT.nmconnection" 2>/dev/null && echo "OUT (для LAN)" || echo "IN (для WAN)")
    [ "$LANGUAGE" = "EN" ] && echo -e $KTS' '$zsh'USB (eth2):'$endc' LAN3-'$(test -f "$FOLDERNM/LAN3-OUT.nmconnection" 2>/dev/null && echo "OUT (for LAN)" || echo "IN (for WAN)")
  fi
  if ip link show eth3 >/dev/null 2>&1; then
    [ "$LANGUAGE" = "RU" ] && echo -e $KTS' '$zsh'USB (eth3):'$endc' LAN4-'$(test -f "$FOLDERNM/LAN4-OUT.nmconnection" 2>/dev/null && echo "OUT (для LAN)" || echo "IN (для WAN)")
    [ "$LANGUAGE" = "EN" ] && echo -e $KTS' '$zsh'USB (eth3):'$endc' LAN4-'$(test -f "$FOLDERNM/LAN4-OUT.nmconnection" 2>/dev/null && echo "OUT (for LAN)" || echo "IN (for WAN)")
  fi
fi

echo

echo -e -n $KTS' '$zsh'WiFi-AP: '$endc''
apconf=/etc/NetworkManager/system-connections/WiFi-AP.nmconnection
wifiap=$(sudo cat $apconf | grep ^ssid= | cut -d= -f2)
conap=$(sudo iw dev | grep $wifiap | wc -l)
if [ $conap -eq 0 ]; then
  [ "$LANGUAGE" = "RU" ] && echo -e ''$rz'ВЫКЛ'$endc'' || echo -e ''$rz'OFF'$endc''
else
  [ "$LANGUAGE" = "RU" ] && echo -e -n ''$gz'ВКЛ'$endc'' || echo -e -n ''$gz'ON'$endc''
  echo -n ' ('$(sudo grep -oP '^interface-name=\K.*' "$apconf" 2>/dev/null)','
  echo -n " $(if [[ $(sudo grep -oP '^channel=\K.*' "$apconf" 2>/dev/null) -lt 14 ]]; then echo "2.4 GHz,"; else echo "5 GHz,"; fi)"
  [ "$LANGUAGE" = "RU" ] && echo -n " канал: $(nmcli -f 802-11-wireless.channel con show WiFi-AP 2>/dev/null | awk '{print $2}')," || echo -n " channel: $(nmcli -f 802-11-wireless.channel con show WiFi-AP 2>/dev/null | awk '{print $2}'),"
  # Проверяем наличие параметра hidden=true в файле конфигурации
  if sudo grep -q "hidden=true" "$apconf" 2>/dev/null; then
    [ "$LANGUAGE" = "RU" ] && echo " скрытая)" || echo " hidden)"
  else
    [ "$LANGUAGE" = "RU" ] && echo " видимая)" || echo " visible)"
  fi
  echo -e -n $KT'  SSID (AP): '$zsh''$wifiap''$endc''
  [ "$LANGUAGE" = "RU" ] && echo -e '  Пароль: '$zsh''$(sudo grep -oP '^psk=\K.*' "$apconf" 2>/dev/null || echo "N/A")''$endc''
  [ "$LANGUAGE" = "EN" ] && echo -e '  Password: '$zsh''$(sudo grep -oP '^psk=\K.*' "$apconf" 2>/dev/null || echo "N/A")''$endc''
  [ "$LANGUAGE" = "RU" ] && echo -e $KT'  Локальный IPv4: '$zsh''$(ip -4 addr show br0 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')''$endc''
  [ "$LANGUAGE" = "EN" ] && echo -e $KT'  Local IPv4: '$zsh''$(ip -4 addr show br0 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')''$endc''
  [ "$LANGUAGE" = "RU" ] && echo -e $KTS'  '$([[ $(ip -6 addr show br0 2>/dev/null | grep -c "inet6") -gt 0 ]] && echo "Локальный IPv6: "$zsh"$(ip -6 addr show br0 2>/dev/null | grep -oP '(?<=inet6\s)[0-9a-f:]+' | head -n1)"$endc || echo "IPv6: "$rz"ВЫКЛ"$endc)
  [ "$LANGUAGE" = "EN" ] && echo -e $KTS'  '$([[ $(ip -6 addr show br0 2>/dev/null | grep -c "inet6") -gt 0 ]] && echo "Local IPv6: "$zsh"$(ip -6 addr show br0 2>/dev/null | grep -oP '(?<=inet6\s)[0-9a-f:]+' | head -n1)"$endc || echo "IPv6: "$rz"OFF"$endc)
fi

echo -e -n $KTS' '$zsh'WiFi-AP2: '$endc''
ap2conf=/etc/NetworkManager/system-connections/WiFi-AP2.nmconnection
wifiap2=$(sudo cat $ap2conf | grep ^ssid= | cut -d= -f2)
br1wc=$(sudo iw dev | grep $wifiap2 | wc -l)
if [ $br1wc -eq 0 ]; then
  [ "$LANGUAGE" = "RU" ] && echo -e ''$rz'ВЫКЛ'$endc'' || echo -e ''$rz'OFF'$endc''
else
  [ "$LANGUAGE" = "RU" ] && echo -e -n ''$gz'ВКЛ'$endc'' || echo -e -n ''$gz'ON'$endc''
  echo -n ' ('$(sudo grep -oP '^interface-name=\K.*' "$ap2conf" 2>/dev/null)','
  echo -n " $(if [[ $(sudo grep -oP '^channel=\K.*' "$ap2conf" 2>/dev/null) -lt 14 ]]; then echo "2.4 GHz,"; else echo "5 GHz,"; fi)"
  [ "$LANGUAGE" = "RU" ] && echo -n " канал: $(nmcli -f 802-11-wireless.channel con show WiFi-AP2 2>/dev/null | awk '{print $2}')," || echo -n " channel: $(nmcli -f 802-11-wireless.channel con show WiFi-AP2 2>/dev/null | awk '{print $2}'),"
  # Проверяем наличие параметра hidden=true в файле конфигурации
  if sudo grep -q "hidden=true" "$ap2conf" 2>/dev/null; then
    [ "$LANGUAGE" = "RU" ] && echo " скрытая)" || echo " hidden)"
  else
    [ "$LANGUAGE" = "RU" ] && echo " видимая)" || echo " visible)"
  fi
  echo -e -n $KT'  SSID (AP2): '$zsh''$wifiap2''$endc''
  [ "$LANGUAGE" = "RU" ] && echo -e '  Пароль: '$zsh''$(sudo grep -oP '^psk=\K.*' "$ap2conf" 2>/dev/null || echo "N/A")''$endc''
  [ "$LANGUAGE" = "EN" ] && echo -e '  Password: '$zsh''$(sudo grep -oP '^psk=\K.*' "$ap2conf" 2>/dev/null || echo "N/A")''$endc''
  [ "$LANGUAGE" = "RU" ] && echo -e $KT'  Локальный IPv4: '$zsh''$(ip -4 addr show br1 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')''$endc''
  [ "$LANGUAGE" = "EN" ] && echo -e $KT'  Local IPv4: '$zsh''$(ip -4 addr show br1 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')''$endc''
  [ "$LANGUAGE" = "RU" ] && echo -e $KTS'  '$([[ $(ip -6 addr show br1 2>/dev/null | grep -c "inet6") -gt 0 ]] && echo "Локальный IPv6: "$zsh"$(ip -6 addr show br1 2>/dev/null | grep -oP '(?<=inet6\s)[0-9a-f:]+' | head -n1)"$endc || echo "IPv6: "$rz"ВЫКЛ"$endc)
  [ "$LANGUAGE" = "EN" ] && echo -e $KTS'  '$([[ $(ip -6 addr show br1 2>/dev/null | grep -c "inet6") -gt 0 ]] && echo "Local IPv6: "$zsh"$(ip -6 addr show br1 2>/dev/null | grep -oP '(?<=inet6\s)[0-9a-f:]+' | head -n1)"$endc || echo "IPv6: "$rz"OFF"$endc)
fi

echo

# Проверка OpenVPN
[ "$LANGUAGE" = "RU" ] && echo -e -n $KTS' '$zsh'OpenVPN-клиент: '$endc'' || echo -e -n $KTS' '$zsh'OpenVPN-client: '$endc''
ACTIVE_OVPN=$(ps -aux | grep -a "/etc/openvpn --config" | awk '{print $20}' | sed 1q | cut -d/ -f4)
[ "$LANGUAGE" = "RU" ] && echo -e ''$(ip link show 2>/dev/null | grep -qE "tun0|tap0" && echo ''$gz'подключено'$endc' (активно: '$ACTIVE_OVPN')' || echo $rz"не подключено"$endc)''
[ "$LANGUAGE" = "EN" ] && echo -e ''$(ip link show 2>/dev/null | grep -qE "tun0|tap0" && echo ''$gz'connected'$endc' (active: '$ACTIVE_OVPN')' || echo $rz"not connected"$endc)''
AUTOSTARTOVPN=$(systemctl is-enabled openvpn 2>/dev/null | grep -o disabled)
if [ "$AUTOSTARTOVPN" = "disabled" ]; then
  [ "$LANGUAGE" = "RU" ] && echo -e -n "$KT  Автоподключение: ${zsh}отключено${endc}" || echo -e -n "$KT  Autostart: ${zsh}disabled${endc}"
else
  [ "$LANGUAGE" = "RU" ] && echo -e -n "$KT  Автоподключение: ${zsh}включено${endc}" || echo -e -n "$KT  Autostart: ${zsh}enabled${endc}"
fi
[ "$LANGUAGE" = "RU" ] && echo -e ' (конфиг: '$zsh''$(sudo cat /etc/default/openvpn | grep ^AUTOSTART= | cut -d= -f2 | sed 's/\"//g')''$endc')' || echo -e ' (config: '$zsh''$(sudo cat /etc/default/openvpn | grep ^AUTOSTART= | cut -d= -f2 | sed 's/\"//g')''$endc')'


