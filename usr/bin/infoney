[ "$LANGUAGE" = "EN" ] && echo -e -n ''$(sudo wg show 2>/dev/null | grep -q "interface" && echo $gz"connected"$endc || echo $rz"not connected"$endc)''
echo -e ' - '$zsh''$(sudo grep -oP '^Endpoint\s*=\s*\K.*' /etc/wireguard/wg0.conf 2>/dev/null || echo "N/A")''$endc''
