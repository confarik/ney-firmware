if [ -f "/tmp/sshdney/sshdney-online" ] && [ -f "/tmp/sshdney/sshdney-hostport" ]; then
  SSHDNEY_INFO=$(sudo grep "^ssh" /tmp/sshdney/sshdney-hostport | cut -d" " -f2 2>/dev/null || echo "N/A")
  # Добавляем TUN статус к sshdney
  SSHDNEY_INFO="$SSHDNEY_INFO$SSH_TUN_STATUS"
fi
# Получаем IP для sshney если файл существует
SSHNEY_INFO=""
if [ -f "/tmp/sshney/sshney-hostport" ]; then
  SSHNEY_INFO=$(sudo grep "^ssh" /tmp/sshney/sshney-hostport | cut -d" " -f2 2>/dev/null || echo "")
fi
# Если нет ни одного IP, устанавливаем N/A
if [ -z "$SSHDNEY_INFO" ] && [ -z "$SSHNEY_INFO" ]; then
  SSHDNEY_INFO="N/A"
  echo -e ' - '$zsh''$SSHDNEY_INFO''$endc''
else
  # Проверяем, есть ли TUN интерфейс и sshdney
  if [ -n "$SSH_TUN_STATUS" ] && [ -n "$SSHDNEY_INFO" ]; then
    # Выводим sshdney информацию
    echo -e ' - '$zsh''$SSHDNEY_INFO''$endc''
    
    # Выводим sshney информацию с отступом и ↑
    if [ -n "$SSHNEY_INFO" ]; then
      echo -e '                                 ↑ '$zsh''$SSHNEY_INFO''$endc''
    fi
  else
    # Если нет TUN или sshdney, выводим sshney как основной без ↑
    if [ -n "$SSHNEY_INFO" ]; then
      echo -e ' - '$zsh''$SSHNEY_INFO''$endc''
    elif [ -n "$SSHDNEY_INFO" ]; then
      # Если есть только sshdney (без TUN)
      echo -e ' - '$zsh''$SSHDNEY_INFO''$endc''
    fi
