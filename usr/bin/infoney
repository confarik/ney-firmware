# Проверка Proxy
[ "$LANGUAGE" = "RU" ] && echo -e -n $KTS' '$zsh'Прокси-клиент: '$endc'' || echo -e -n $KTS' '$zsh'Proxy-client: '$endc''
if test -f "/tmp/proxyney/proxyney-online" 2>/dev/null || test -f "/tmp/proxydney/proxydney-online" 2>/dev/null; then
  [ "$LANGUAGE" = "RU" ] && echo -e -n $gz"подключено"$endc || echo -e -n $gz"connected"$endc
else
  [ "$LANGUAGE" = "RU" ] && echo -e -n $rz"не подключено"$endc || echo -e -n $rz"not connected"$endc
fi
# Проверяем наличие TUN интерфейса
TUN_STATUS=""
if sudo ip tuntap 2>/dev/null | grep -q "pr0"; then
  TUN_STATUS=" $skyz(TUN)$endc"
fi
# Получаем IP для proxydney (TUN) если файл существует
PROXYDNEY_INFO=""
if [ -f "/tmp/proxydney/proxydney-online" ] && [ -f "/tmp/proxydney/proxydney" ]; then
  PROXYDNEY_INFO=$(sudo awk '/parent 1000/{type=$3} /parent 1000/{ip=$4} /parent 1000/{port=$5} END{if(type!="" && ip!="" && port!="") print "("type")"" "ip":"port; else print "N/A"}' /tmp/proxydney/proxydney 2>/dev/null || echo "N/A")
  # Добавляем TUN статус к proxydney
  PROXYDNEY_INFO="$PROXYDNEY_INFO$TUN_STATUS"
fi
# Получаем IP для proxyney если файл существует
PROXYNEY_INFO=""
if [ -f "/tmp/proxyney/proxyney" ]; then
  PROXYNEY_INFO=$(sudo awk '/parent 1000/{type=$3} /parent 1000/{ip=$4} /parent 1000/{port=$5} END{if(type!="" && ip!="" && port!="") print "("type")"" "ip":"port; else print ""}' /tmp/proxyney/proxyney 2>/dev/null || echo "")
fi
# Если нет ни одного IP, устанавливаем N/A
if [ -z "$PROXYDNEY_INFO" ] && [ -z "$PROXYNEY_INFO" ]; then
  PROXYDNEY_INFO="N/A"
  echo -e ' - '$zsh''$PROXYDNEY_INFO''$endc''
else
  # Проверяем, есть ли TUN интерфейс и proxydney
  if [ -n "$TUN_STATUS" ] && [ -n "$PROXYDNEY_INFO" ]; then
    # Выводим proxydney информацию
    echo -e ' - '$zsh''$PROXYDNEY_INFO''$endc''
    
    # Выводим proxyney информацию с отступом и ↑
    if [ -n "$PROXYNEY_INFO" ]; then
      echo -e '                                 ↑ '$zsh''$PROXYNEY_INFO''$endc''
    fi
  else
    # Если нет TUN или proxydney, выводим proxyney как основной без ↑
    if [ -n "$PROXYNEY_INFO" ]; then
      echo -e ' - '$zsh''$PROXYNEY_INFO''$endc''
    elif [ -n "$PROXYDNEY_INFO" ]; then
      # Если есть только proxydney (без TUN)
      echo -e ' - '$zsh''$PROXYDNEY_INFO''$endc''
    fi
  fi
fi

