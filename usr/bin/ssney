#!/bin/bash
export LASTCMD=$@
# Загрузка настроек языка
LANGUAGE_CONFIG="/etc/language-ney.conf"
if [ -f "$LANGUAGE_CONFIG" ]; then
  source "$LANGUAGE_CONFIG"
else
  LANGUAGE="EN"
fi

# Установка локали в зависимости от выбранного языка
if [ "$LANGUAGE" = "RU" ]; then
  # Если выбран русский, проверяем наличие русской локали
  if locale -a 2>/dev/null | grep -q 'ru_RU.utf8\|ru_RU.UTF-8'; then
    export LC_ALL=ru_RU.UTF-8
    export LANG=ru_RU.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
else
  # Если выбран английский, используем английскую локаль
  if locale -a 2>/dev/null | grep -q 'en_US.utf8\|en_US.UTF-8'; then
    export LC_ALL=en_US.UTF-8
    export LANG=en_US.UTF-8
  else
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
  fi
fi
#######################################################################
#
#  /$$      /$$
# | $$$    /$$$
# | $$$$  /$$$$  /$$$$$$   /$$$$$$   /$$$$$$$
# | $$ $$/$$ $$ |____  $$ /$$__  $$ /$$_____/
# | $$  $$$| $$  /$$$$$$$| $$  \__/|  $$$$$$
# | $$\  $ | $$ /$$__  $$| $$       \____  $$
# | $$ \/  | $$|  $$$$$$$| $$       /$$$$$$$/
# |__/     |__/ \_______/|__/      |_______/
#
# Telegram: @confxwho
#######################################################################
rz='\033[1;31m' #'$rz'
mrz='\033[1;91m' #'$mrz'
gz='\033[1;32m' #'$gz'
yz='\033[1;33m' #'$yz'
myz='\033[1;93m' #'$myz'
skyz='\033[1;36m' #'$skyz'
bz='\033[44;37m' #'$bz'
zsh='\033[1m' #'$zsh'
blink='\033[5;33m' # Мигающий желтый текст
endc='\033[0m' #'$endc'

QUIET_MODE=false
if [ "$1" = "-q" ]; then
  QUIET_MODE=true
  shift
fi
NO_BLOCK_WEBRTC=false
if [ "$1" = "-w" ]; then
  NO_BLOCK_WEBRTC=true
  shift
fi
MANUAL_DNS=false
MANUAL_DNS_VALUE=""
if [ "$1" = "-d" ]; then
  MANUAL_DNS=true
  MANUAL_DNS_VALUE="$2"
  shift 2
fi

if ! $QUIET_MODE; then
echo -e =========='|'$bz' SSNey 3.1 '$endc'|'=========
fi

if [ "$LANGUAGE" = "RU" ]; then
    CONTACT="[*] ${skyz}Телеграм${endc} контакт: ${yz}@confxwho${endc}
[*]          канал: ${yz}@confxwho${endc}"
else
    CONTACT="[*] ${skyz}Telegram${endc} contact: ${yz}@confxwho${endc}
[*]          channel: ${yz}@confxwho${endc}"
fi
SERIALNEYPI=$(grep -oP 'Serial\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
REVISIONNEYPI=$(grep -oP 'Revision\s*:\s*\K.*' /proc/cpuinfo 2>/dev/null)
SERIAL_FILE="/etc/security/${SERIALNEYPI}"
if [[ $SERIALNEYPI != a6bb65ad2ae10c15 ]] || [[ $REVISIONNEYPI != b04171 ]] || \
   [[ ! -f "$SERIAL_FILE" ]] || [[ "$(cat "$SERIAL_FILE" 2>/dev/null)" != "$SERIALNEYPI" ]]; then
     echo -e "$CONTACT"
     echo =================================
     exit 1
fi

ROUTEAP=br0
LSERVER=$(ifconfig $ROUTEAP | grep "inet " | awk '{print $2}' | cut -d/ -f1)
SSHSERPORT=$(sudo cat /etc/ssh/sshd_config | grep "Port " | awk '{print $2}' | head -n1)
IPTNAME=SSNEY
IPINET=0.0.0.0
DNS=208.67.220.220
LPDNS=533
PLUGINHOST=www.openstreetmap.org
LOCALDNS=$LSERVER:$LPDNS/tcp
HOMENEY=/home/ney
HISTORY=/etc/history-vpn-proxy

is_ip() {
    local check_str=$1
    [[ -z "$check_str" ]] && return 1
    [[ $check_str =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]] && return 0
    [[ $check_str == *"."* && $check_str != *" "* ]] && return 0
    return 1
}
start_ssney() {
  sslocal -c $SSNEY_CONF 1>/dev/null 2>&1 &
  sleep 2
  3proxy $PROXYFORSSNEY_CONF
  sleep 1
  sudo iptables -t nat -N $IPTNAME
  sudo iptables -t nat -A $IPTNAME -p tcp --dport 5380 -j REDIRECT --to-ports 5380
  sudo iptables -t nat -A $IPTNAME -p tcp --dport $SSHSERPORT -j REDIRECT --to-ports $SSHSERPORT
  sudo iptables -t nat -A $IPTNAME -p tcp --syn -j REDIRECT --to-ports $PROXYFORSSNEY_PORT
  sudo iptables -t nat -A $IPTNAME -p udp --dport 53 -j REDIRECT --to-ports $LPDNS
  sudo iptables -t nat -A PREROUTING -i $ROUTEAP -j $IPTNAME
}
start_webrtcoff() {
  sudo iptables -t raw -I PREROUTING -p udp -m multiport --dports 3478,19302,19305 -j DROP
}
start_iptsecurity() {
  sudo iptables -I FORWARD -i $ROUTEAP -p udp -j REJECT --reject-with icmp-port-unreachable
  sudo iptables -I FORWARD -i $ROUTEAP -m conntrack --ctstate INVALID -j DROP
  sudo iptables -I FORWARD -i $ROUTEAP -m state --state INVALID -j DROP
  sudo iptables -I FORWARD -i $ROUTEAP -m state --state RELATED,ESTABLISHED -j DROP
  sudo iptables -I FORWARD -i $ROUTEAP -p tcp --tcp-flags ACK,FIN ACK,FIN -j DROP
  sudo iptables -I FORWARD -i $ROUTEAP -p tcp --tcp-flags ACK,RST ACK,RST -j DROP
}
stop_ssney() {
  killall 3proxy 1>/dev/null 2>&1
  killall sslocal 1>/dev/null 2>&1
  sudo rm -rf /tmp/ssney 1>/dev/null 2>&1
  sudo iptables -t nat -D PREROUTING -i $ROUTEAP -j $IPTNAME 1>/dev/null 2>&1
  sudo iptables -t nat -F $IPTNAME 1>/dev/null 2>&1
  sudo iptables -t nat -X $IPTNAME 1>/dev/null 2>&1
}
stop_webrtcoff() {
  sudo iptables -t raw -D PREROUTING -p udp -m multiport --dports 3478,19302,19305 -j DROP 1>/dev/null 2>&1
}
stop_iptsecurity() {
  sudo iptables -D FORWARD -i $ROUTEAP -p udp -j REJECT --reject-with icmp-port-unreachable 1>/dev/null 2>&1
  sudo iptables -D FORWARD -i $ROUTEAP -m conntrack --ctstate INVALID -j DROP 1>/dev/null 2>&1
  sudo iptables -D FORWARD -i $ROUTEAP -m state --state INVALID -j DROP 1>/dev/null 2>&1
  sudo iptables -D FORWARD -i $ROUTEAP -m state --state RELATED,ESTABLISHED -j DROP 1>/dev/null 2>&1
  sudo iptables -D FORWARD -i $ROUTEAP -p tcp --tcp-flags ACK,FIN ACK,FIN -j DROP 1>/dev/null 2>&1
  sudo iptables -D FORWARD -i $ROUTEAP -p tcp --tcp-flags ACK,RST ACK,RST -j DROP 1>/dev/null 2>&1
}
usage() {
  if [ "$LANGUAGE" = "RU" ]; then
cat << EOF
[*] Использование: sudo ssney [опции]
[*] Опции:
[*]  [метод] [IP] [порт] [пароль]                    - подключить Shadowsocks
[*]  [метод] [IP] [порт] [пароль] [палгин]           - подключить Shadowsocks с плагином.
[*]  [метод] [IP] [порт] [пароль] [палгин] -h [WWW]  - подключить Shadowsocks с плагином с другим хостом.
[*]  -d [IP-DNS]                                     - ручной DNS (ставить перед [метод])
[*]  -w                                              - не блокировать WebRTC (ставить -w после слова ssney)
[*]
[*]  -s, stop                                        - отсоединить
[*]  clear                                           - очистить историю
[*]  import                                          - импортировать историю подключений
[*]  export                                          - экспортировать историю подключений 
[*]
[*] [метод]: plain, none,
[*]          aes-128-gcm, aes-256-gcm, chacha20-ietf-poly1305,
[*]          2022-blake3-aes-128-gcm, 2022-blake3-aes-256-gcm,
[*]          2022-blake3-chacha20-poly1305, 2022-blake3-chacha8-poly1305
[*]
[*] [палгин]: obfs-http, obfs-tls, cloak,
[*]           v2ray, v2ray-tls, v2ray-quic, v2ray-grpc, v2ray-grpc-tls,
[*]           xray, xray-tls, xray-quic, xray-grpc, xray-grpc-tls
[*]
[*] Контакт: телеграм @confxwho (никнейм: Ney)
=================================
EOF
  else
cat << EOF
[*] Usage: sudo ssney [options]
[*] Options:
[*]  [METHOD] [IP] [PORT] [PASSWORD]                    - connect Shadowsocks
[*]  [METHOD] [IP] [PORT] [PASSWORD] [PLUGIN]           - connect Shadowsocks with plugin.
[*]  [METHOD] [IP] [PORT] [PASSWORD] [PLUGIN] -h [WWW]  - connect Shadowsocks with plugin with a different WWW.
[*]  -d [IP-DNS]                                        - manual DNS (put before [METHOD])
[*]  -w                                                 - do not block WebRTC (put -w after ssney)
[*]
[*]  -s, stop                                           - disconnect
[*]  clear                                              - clear history
[*]  import                                             - import history connections
[*]  export                                             - export history connections
[*]
[*] [METHOD]: plain, none,
[*]           aes-128-gcm, aes-256-gcm, chacha20-ietf-poly1305,
[*]           2022-blake3-aes-128-gcm, 2022-blake3-aes-256-gcm,
[*]           2022-blake3-chacha20-poly1305, 2022-blake3-chacha8-poly1305
[*]
[*] [PLUGIN]: obfs-http, obfs-tls, cloak,
[*]           v2ray, v2ray-tls, v2ray-quic, v2ray-grpc, v2ray-grpc-tls,
[*]           xray, xray-tls, xray-quic, xray-grpc, xray-grpc-tls
[*]
[*] Contact: telegram @confxwho (nickname: Ney)
=================================
EOF
  fi
}
[ "$#" = "0" ] && usage && exit 1
while [ $# -gt 0 ]
do
option="$1"
case $option in
    manager)
    # Проверяем подключение любого shadowsocks
    if test -f "/tmp/ssney/ssney-online" 2>/dev/null || test -f "/tmp/ssdney/ssdney-online" 2>/dev/null; then
      [ "$LANGUAGE" = "RU" ] && SSNEY_CONNECTED="подключено" || SSNEY_CONNECTED="connected"
    else
      [ "$LANGUAGE" = "RU" ] && SSNEY_CONNECTED="не подключено" || SSNEY_CONNECTED="not connected"
    fi
    
    # Проверяем наличие TUN интерфейса
    TUN_STATUS=""
    if sudo ip tuntap 2>/dev/null | grep -q "ss0"; then
      TUN_STATUS="(TUN)"
    fi
    
    # Получаем информацию о ssdney и ssney
    SSDNEY_INFO=""
    if [ -f "/tmp/ssdney/ssdney-online" ] && [ -f "/tmp/ssdney/ssdney" ]; then
      SSDNEY_INFO=$(sudo awk -F'[," ]' '/server/{ip=$5} /server_port/{port=$11} END{if(ip!="" && port!="") print ip":"port; else print "N/A"}' /tmp/ssdney/ssdney 2>/dev/null || echo "N/A")
    fi
    
    SSNEY_INFO=""
    if [ -f "/tmp/ssney/ssney" ]; then
      SSNEY_INFO=$(sudo awk -F'[," ]' '/server/{ip=$5} /server_port/{port=$11} END{if(ip!="" && port!="") print ip":"port; else print "N/A"}' /tmp/ssney/ssney 2>/dev/null || echo "N/A")
    fi
    
    # Формируем LAST_SERVERIP для отображения
    if [ -n "$TUN_STATUS" ] && [ -n "$SSDNEY_INFO" ]; then
      # Если есть TUN и ssdney, показываем оба
      LAST_SERVERIP="$SSDNEY_INFO $TUN_STATUS"
      if [ -n "$SSNEY_INFO" ]; then
        LAST_SERVERIP="$LAST_SERVERIP ← $SSNEY_INFO"
      fi
    else
      # Иначе показываем тот, который есть
      if [ -n "$SSNEY_INFO" ]; then
        LAST_SERVERIP="$SSNEY_INFO"
      elif [ -n "$SSDNEY_INFO" ]; then
        LAST_SERVERIP="$SSDNEY_INFO"
      else
        LAST_SERVERIP="N/A"
      fi
    fi
    
    CHECK_TUN=$TUN_STATUS

    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
[*] Shadowsocks-клиент: $SSNEY_CONNECTED - $LAST_SERVERIP

enter: подключить
u: обновить протокол
n: подключить новый
s: отсоединить
c: очистить историю
ctrl-i: импортировать
ctrl-e: экспортировать
ESC: выйти"
      EXIT_MSG="Для выхода нажмите любую клавишу"
      BORDER_LABEL="| Менеджер Shadowsocks-клиент |"
    else
      FZF_HEADER="
[*] Shadowsocks-client: $SSNEY_CONNECTED - $LAST_SERVERIP

enter: re-connect 
u: update protocol
n: connect new
s: stop
c: clear history
ctrl-i: import history
ctrl-e: export history
ESC: exit"
      EXIT_MSG="Press any key to exit"
      BORDER_LABEL="| Shadowsocks-client manager |"
    fi
    HISTORYSS=$(cat $HISTORY/ssney-h 2>/dev/null | sort -r -k2,2 | sed "s/NO ASN/$(echo -e "$yz")NO ASN$(echo -e "$endc")/g" | sed "s/NO AUTO DNS/$(echo -e "$yz")NO AUTO DNS$(echo -e "$endc")/g" | sed "s/NO VALID/$(echo -e "$rz")NO VALID$(echo -e "$endc")/g" | sed "s/  VALID/$(echo -e "$gz")  VALID$(echo -e "$endc")/g" | fzf --ansi \
      --header="$FZF_HEADER" \
      --bind='enter:execute(sudo $(echo {} | grep -o "ss[d]*ney.*"); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(ssney -q manager)' \
      --bind='u:execute(sudo ssney -q new $(echo {} | grep -Eo "(plain|none|aes-128-gcm|aes-256-gcm|chacha20-ietf-poly1305|2022-blake3-aes-128-gcm|2022-blake3-aes-256-gcm|2022-blake3-chacha20-poly1305|2022-blake3-chacha8-poly1305).*" | cut -d" " -f1,2,3,4,5,6,7); echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(ssney -q manager)' \
      --bind='n:execute(sudo ssney -q new; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -n 1 -s)+become(ssney -q manager)' \
      --bind='s:execute(sudo ssney stop-ss-ssd && sleep 1)+become(ssney -q manager)' \
      --bind='c:execute-silent(sudo ssney clear && sleep 1)+become(ssney -q manager)' \
      --bind='ctrl-i:execute(sudo ssney -q import; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+become(ssney -q manager)' \
      --bind='ctrl-e:execute(sudo ssney -q export; echo -e "\033[2;37m[*] '"$EXIT_MSG"'\033[0m"; read -t 2 -n 1 -s)+reload(ssney -q manager)' \
      --layout=default --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
      --height=40% --info=inline --margin=1 --padding=1)
    if [ -z "$HISTORYSS" ]; then
      if ! $QUIET_MODE; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
      fi
      exit 1
    fi
    exit 0
    ;;

    new)
    if [ -n "$2" ]; then
        server_info="$2 $3 $4 $5 $6 $8"
    else
        while true; do
          if [ "$LANGUAGE" = "RU" ]; then
            echo -e [*] ''$zsh'Введите данные Shadowsocks в одном из любых форматов:'$endc''
            echo -e [*] '  метод:IP/Host:порт:пароль:плагин'
            echo -e [*] '  метод:IP/Host:порт:пароль:плагин:WWW'
            echo -e [*] '  метод IP/Host порт пароль плагин WWW'
            echo -e [*] '  метод|IP/Host|порт|пароль|плагин WWW'
            echo -e [*]
            read -p "Вставьте или введите данные Shadowsocks: " server_info
          else
            echo -e [*] ''$zsh'Enter Shadowsocks data in one of the following formats:'$endc''
            echo -e [*] '  METHOD:IP/Host:PORT:PASSWORD:PLUGIN'
            echo -e [*] '  METHOD:IP/Host:PORT:PASSWORD:PLUGIN:WWW'
            echo -e [*] '  METHOD IP/Host PORT PASSWORD PLUGIN WWW'
            echo -e [*] '  METHOD|IP/Host|PORT|PASSWORD|PLUGIN WWW'
            echo -e [*]
            read -p "Paste or enter Shadowsocks data: " server_info
          fi
          break
        done
    fi
    
    # Определяем разделитель и разбиваем строку
    ss_method=""
    ss_ip=""
    ss_port=""
    ss_password=""
    ss_plugin=""
    ss_host=""
    
    # Функция для проверки, является ли строка портом
    is_port() {
        local check_str=$1
        [[ $check_str =~ ^[0-9]+$ ]] && [ $check_str -ge 1 ] && [ $check_str -le 65535 ]
        return $?
    }
    
    # Функция для проверки, является ли строка допустимым методом шифрования
    is_valid_method() {
        local method=$1
        case $method in
            plain|none|aes-128-gcm|aes-256-gcm|chacha20-ietf-poly1305|2022-blake3-aes-128-gcm|2022-blake3-aes-256-gcm|2022-blake3-chacha20-poly1305|2022-blake3-chacha8-poly1305)
                return 0
                ;;
            *)
                return 1
                ;;
        esac
    }
    
    # Функция для проверки, является ли строка допустимым плагином
    is_valid_plugin() {
        local plugin=$1
        case $plugin in
            ""|obfs-http|obfs-tls|cloak|v2ray|v2ray-tls|v2ray-quic|v2ray-grpc|v2ray-grpc-tls|xray|xray-tls|xray-quic|xray-grpc|xray-grpc-tls)
                return 0
                ;;
            *)
                return 1
                ;;
        esac
    }
    
    # Определяем разделитель по наличию в строке
    if [[ $server_info == *":"* ]]; then
        IFS=':' read -r ss_method ss_ip ss_port ss_password ss_plugin ss_host <<< "$server_info"
    elif [[ $server_info == *"|"* ]]; then
        IFS='|' read -r ss_method ss_ip ss_port ss_password ss_plugin ss_host <<< "$server_info"
    else
        # Предполагаем разделитель - пробел
        read -r ss_method ss_ip ss_port ss_password ss_plugin ss_host <<< "$server_info"
    fi
    
    # Проверка наличия обязательных параметров
    if [ -z "$ss_method" ] || [ -z "$ss_ip" ] || [ -z "$ss_port" ] || [ -z "$ss_password" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: недостаточно параметров. Необходимы Метод, IP/Host, порт и пароль.${endc}" || echo -e "[*] ${rz}Error: insufficient parameters. Required Method, IP/Host, PORT and PASSWORD.${endc}"
        continue
    fi
    
    # Проверка метода шифрования
    if ! is_valid_method "$ss_method"; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный метод шифрования.${endc}" || echo -e "[*] ${rz}Error: invalid encryption method.${endc}"
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Допустимые методы: plain, none, aes-128-gcm, aes-256-gcm, chacha20-ietf-poly1305,${endc}" || echo -e "[*] ${yz}Allowed encryption methods: plain, none, aes-128-gcm, aes-256-gcm, chacha20-ietf-poly1305,${endc}"
        echo -e "[*] ${yz}2022-blake3-aes-128-gcm, 2022-blake3-aes-256-gcm, 2022-blake3-chacha20-poly1305, 2022-blake3-chacha8-poly1305${endc}"
        continue
    fi
    
    # Проверка IP/хоста
    if ! is_ip "$ss_ip"; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный формат IP-адреса: $ss_ip.${endc}" || echo -e "[*] ${rz}Error: invalid IP address format: $ss_ip.${endc}"
        continue
    fi
    
    # Проверка порта
    if ! is_port "$ss_port"; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный порт: $ss_port. Должен быть в диапазоне от 1 до 65535.${endc}" || echo -e "[*] ${rz}Error: invalid port: $ss_port. Must be in the range from 1 to 65535.${endc}"
        continue
    fi
    
    # Проверка плагина, если указан
    if [ -n "$ss_plugin" ] && ! is_valid_plugin "$ss_plugin"; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный плагин: $ss_plugin.${endc}" || echo -e "[*] ${rz}Error: invalid plugin: $ss_plugin.${endc}"
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Допустимые плагины: obfs-http, obfs-tls, cloak, v2ray, v2ray-tls, v2ray-quic,${endc}" || echo -e "[*] ${yz}Allowed plugins: obfs-http, obfs-tls, cloak, v2ray, v2ray-tls, v2ray-quic,${endc}"
        echo -e "[*] ${yz}v2ray-grpc, v2ray-grpc-tls, xray, xray-tls, xray-quic, xray-grpc, xray-grpc-tls${endc}"
        continue
    fi
    
    # Проверка необходимости хоста для плагина
    if [ -n "$ss_plugin" ] && [[ ! "$ss_plugin" =~ ^(cloak|v2ray|xray)$ ]] && [ -z "$ss_host" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Информация:${endc} Для плагина $ss_plugin необходимо указать хост WWW." || echo -e "[*] ${yz}Information:${endc} For plugin $ss_plugin you need to specify a host WWW."
        [ "$LANGUAGE" = "RU" ] && echo -e "[*]   (enter - www.openstreetmap.org (по умолчанию), или укажите другой)" || echo -e "[*]   (enter - www.openstreetmap.org (default), or specify another)"
        [ "$LANGUAGE" = "RU" ] && read -p "Вставьте или введите хост: " ss_host
        [ "$LANGUAGE" = "EN" ] && read -p "Paste or enter host: " ss_host
        if [ -z "$ss_host" ]; then
            ss_host="www.openstreetmap.org"
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] Используется хост по умолчанию: $ss_host" || echo -e "[*] Using default host: $ss_host"
        fi
    fi
    
    # Вывод информации о сервере
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Метод: ${zsh}$ss_method${endc}" || echo -e "[*] Method: ${zsh}$ss_method${endc}"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Сервер IP/Host: ${zsh}$ss_ip${endc}" || echo -e "[*] Server IP/Host: ${zsh}$ss_ip${endc}"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Порт сервера: ${zsh}$ss_port${endc}" || echo -e "[*] Server port: ${zsh}$ss_port${endc}"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Пароль: ${zsh}$ss_password${endc}" || echo -e "[*] Password: ${zsh}$ss_password${endc}"
    if [ -n "$ss_plugin" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}$ss_plugin${endc}" || echo -e "[*] Plugin: ${zsh}$ss_plugin${endc}"
        if [ -n "$ss_host" ]; then
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$ss_host${endc}" || echo -e "[*] Host WWW: ${zsh}$ss_host${endc}"
        fi
    fi

    if [ "$LANGUAGE" = "RU" ]; then
      FZF_HEADER="
enter: выбрать
ESC: выход
      Режим подключения:"
      BORDER_LABEL="| Менеджер Shadowsocks-клиент |"
      INTERACTIVE=" [1]  Только TCP (DNS over TCP) (ssney)
 [2]  TCP и UDP (TUN с DNS, WebRTC(если имеется)) (ssdney)"
    else
      FZF_HEADER="
enter: select
ESC: exit
      Connection mode:"
      BORDER_LABEL="| Shadowsocks-client manager |"
      INTERACTIVE=" [1]  Only TCP (DNS over TCP) (ssney)
 [2]  TCP and UDP (TUN with DNS, WebRTC(if available)) (ssdney)"
    fi
    connection_mode=$(echo "$INTERACTIVE" | fzf --ansi --pointer=">" \
          --header="$FZF_HEADER" \
          --bind='enter:become(echo {})' \
          --layout=reverse --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
          --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$connection_mode" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 0
      fi
      case $connection_mode in
        *"[1]"*) USE_TUN="false" ;;
        *"[2]"*) USE_TUN="true" ;;
      esac
    
    # WebRTC только для обычной версии ssney
    if [ "$USE_TUN" != "true" ]; then
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: выбрать
ESC: выход
      Настройка WebRTC:"
        BORDER_LABEL="| Менеджер Shadowsocks-клиент |"
        INTERACTIVE=" [1]  Блокировать WebRTC
 [2]  Не блокировать WebRTC (небезопасно)"
      else
        FZF_HEADER="
enter: select
ESC: exit
      WebRTC configuration:"
        BORDER_LABEL="| Shadowsocks-client manager |"
        INTERACTIVE=" [1]  Block WebRTC
 [2]  Do not block WebRTC (not secure)"
      fi
      webrtc_option=$(echo "$INTERACTIVE" | fzf --ansi --pointer=">" \
          --header="$FZF_HEADER" \
          --bind='enter:become(echo {})' \
          --layout=reverse --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
          --height=40% --info=inline --margin=1 --padding=1)
      case $webrtc_option in
        *"[1]"*) NO_BLOCK_WEBRTC="false" ;;
        *"[2]"*) NO_BLOCK_WEBRTC="true"
                 additional_options="-w" ;;
      esac
    fi
    
    # DNS опции - только для обычного режима ssney
    if [ "$USE_TUN" != "true" ]; then
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: выбрать
ESC: выход
      Настройка DNS:"
        BORDER_LABEL="| Менеджер Shadowsocks-клиент |"
        INTERACTIVE=" [1]  DNS: 208.67.220.220 (по умолчанию)
 [2]  Ручной DNS"
      else
        FZF_HEADER="
enter: select
ESC: exit
      DNS configuration:"
        BORDER_LABEL="| Shadowsocks-client manager |"
        INTERACTIVE=" [1]  DNS: 208.67.220.220 (default)
 [2]  Manual DNS"
      fi
      dns_option=$(echo "$INTERACTIVE" | fzf --ansi --pointer=">" \
          --header="$FZF_HEADER" \
          --bind='enter:become(echo {})' \
          --layout=reverse --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
          --height=40% --info=inline --margin=1 --padding=1)
      case $dns_option in
        *"[1]"*) ;;
        *"[2]"*)
          [ "$LANGUAGE" = "RU" ] && read -p "Введите IP-адрес DNS: " manual_dns
          [ "$LANGUAGE" = "EN" ] && read -p "Enter the DNS IP address: " manual_dns
          if ! [[ $manual_dns =~ ^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$ ]]; then
            [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: неверный формат IP-адреса DNS.${endc}" || echo -e "[*] ${rz}Error: invalid IP address format for DNS.${endc}"
            exit 1
          fi
          additional_options="$additional_options -d $manual_dns"
          ;;
      esac
    fi
    
    # Формируем команду в зависимости от выбранного режима
    if [ "$USE_TUN" = "true" ]; then
        # Используем ssdney для TUN и поддержки UDP
        command_to_run="sudo ssdney"
    else
        # Используем обычный ssney
        command_to_run="sudo ssney"
        # Добавляем параметр WebRTC, если необходимо
        if [ "$NO_BLOCK_WEBRTC" = "true" ]; then
            command_to_run="$command_to_run -w"
        fi
        # Добавляем параметр DNS, но только если это не DNS по умолчанию
        if [ "$use_default_dns" != "true" ] && [ -n "$manual_dns" ]; then
            command_to_run="$command_to_run -d $manual_dns"
        fi
    fi
    
    # Добавляем основные параметры, одинаковые для обоих режимов
    command_to_run="$command_to_run $ss_method $ss_ip $ss_port $ss_password"
    
    # Добавляем плагин, если указан
    if [ -n "$ss_plugin" ]; then
        command_to_run="$command_to_run $ss_plugin"
    fi
    # Добавляем параметр -h для плагинов, которые требуют хост
    if [ -n "$ss_host" ]; then
        command_to_run="$command_to_run -h $ss_host"
    fi
    eval $command_to_run
    break
    ;;

    plain|none|aes-128-gcm|aes-256-gcm|chacha20-ietf-poly1305|2022-blake3-aes-128-gcm|2022-blake3-aes-256-gcm|2022-blake3-chacha20-poly1305|2022-blake3-chacha8-poly1305)
    METHOD=$option SERVERIP="$2" SERVERPORT="$3" SERVERPASS="$4" VULPLUGIN="$5"
    if is_ip "$SERVERIP"; then
      if [[ "$SERVERPORT" =~ ^[0-9]+$ ]] && [ "$SERVERPORT" -ge 1 ] && [ "$SERVERPORT" -le 65535 ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Сервер IP/Host: ${zsh}$SERVERIP${endc}" || echo -e "[*] Server IP/Host: ${zsh}$SERVERIP${endc}"
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Порт сервера: ${zsh}$SERVERPORT${endc}" || echo -e "[*] Server port: ${zsh}$SERVERPORT${endc}"
        # Если SERVERIP - это доменное имя, преобразуем его в IP
        if [[ ! $SERVERIP =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
          SERVER_IP_RESOLVED=$(host $SERVERIP | grep 'has address' | head -1 | awk '{print $4}')
          if [ -n "$SERVER_IP_RESOLVED" ]; then
            SERVERIP_ORIG=$SERVERIP
            SERVERIP=$SERVER_IP_RESOLVED
          fi
        fi
      else
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: Вы ввели неверный порт.${endc}" || echo -e "[*] ${rz}Error: Invalid port number.${endc}"
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Информация:${endc} Число должно находиться в диапазоне от 1 до 65535." || echo -e "[*] ${yz}Information:${endc} The number must be between 1 and 65535."
        echo =================================
        exit 1;
      fi
    else
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: Вы ввели неверный IP-адрес или хост.${endc}" || echo -e "[*] ${rz}Error: Invalid IP address or host.${endc}"
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Информация:${endc} Введите корректный IP или хост." || echo -e "[*] ${yz}Information:${endc} Enter a valid IP or host."
      echo =================================
      exit 1;
    fi
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Пароль: ${zsh}$SERVERPASS${endc}" || echo -e "[*] Password: ${zsh}$SERVERPASS${endc}"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Метод: ${zsh}$METHOD${endc}" || echo -e "[*] Method: ${zsh}$METHOD${endc}"

    # Проверяем, есть ли параметр -h в командной строке
    MANUAL_PLUGINHOST=false
    MANUAL_PLUGINHOST_VALUE=""
    # Проверяем все аргументы на наличие -h
    for arg in "$@"; do
      if [ "$MANUAL_PLUGINHOST" = "true" ]; then
        MANUAL_PLUGINHOST_VALUE="$arg"
        PLUGINHOST="$MANUAL_PLUGINHOST_VALUE"
        MANUAL_PLUGINHOST=false
        break
      fi
      if [ "$arg" = "-h" ]; then
        MANUAL_PLUGINHOST=true
      fi
    done
    # Если нашли -h, но не нашли значение, выводим ошибку
    if [ "$MANUAL_PLUGINHOST" = "true" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: после параметра -h требуется указать хост WWW.${endc}" || echo -e "[*] ${rz}Error: after parameter -h, the host WWW is required.${endc}"
      echo =================================
      exit 1
    fi
mode_str1='"mode": "tcp_and_udp",'
if [[ "$VULPLUGIN" == "obfs-http" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}obfs-http${endc}" || echo -e "[*] Plugin: ${zsh}obfs-http${endc}"
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  plugin_str1='"plugin":"obfs-local",'
  plugin_str2='"plugin_opts":"obfs=http;obfs-host='$PLUGINHOST'"'
fi
if [[ "$VULPLUGIN" == "obfs-tls" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}obfs-tls${endc}" || echo -e "[*] Plugin: ${zsh}obfs-tls${endc}"
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  plugin_str1='"plugin":"obfs-local",'
  plugin_str2='"plugin_opts":"obfs=tls;host='$PLUGINHOST'"'
fi
