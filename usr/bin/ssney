  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  plugin_str1='"plugin":"v2ray-plugin",'
  plugin_str2='"plugin_opts":"tls;mode=grpc;host='$PLUGINHOST'"'
fi
#############xray
if [[ "$VULPLUGIN" == "xray" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}xray${endc}" || echo -e "[*] Plugin: ${zsh}xray${endc}"
  plugin_str1='"plugin":"xray-plugin"'
fi
if [[ "$VULPLUGIN" == "xray-tls" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}xray-tls${endc}" || echo -e "[*] Plugin: ${zsh}xray-tls${endc}"
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  plugin_str1='"plugin":"xray-plugin",'
  plugin_str2='"plugin_opts":"tls;host='$PLUGINHOST'"'
fi
if [[ "$VULPLUGIN" == "xray-quic" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}xray-quic${endc}" || echo -e "[*] Plugin: ${zsh}xray-quic${endc}"
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  mode_str1='"mode": "tcp_only",'
  plugin_str1='"plugin":"xray-plugin",'
  plugin_str2='"plugin_opts":"mode=quic;host='$PLUGINHOST'"'
fi
if [[ "$VULPLUGIN" == "xray-grpc" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}xray-grpc${endc}" || echo -e "[*] Plugin: ${zsh}xray-grpc${endc}"
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  plugin_str1='"plugin":"xray-plugin",'
  plugin_str2='"plugin_opts":"mode=grpc"'
fi
if [[ "$VULPLUGIN" == "xray-grpc-tls" ]]; then
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Плагин: ${zsh}xray-grpc-tls${endc}" || echo -e "[*] Plugin: ${zsh}xray-grpc-tls${endc}"
  [ "$LANGUAGE" = "RU" ] && echo -e "[*] Хост WWW: ${zsh}$PLUGINHOST${endc}" || echo -e "[*] Host WWW: ${zsh}$PLUGINHOST${endc}"
  plugin_str1='"plugin":"xray-plugin",'
  plugin_str2='"plugin_opts":"tls;mode=grpc;host='$PLUGINHOST'"'
fi

    if [ "$MANUAL_DNS" = "true" ]; then
      DNS="$MANUAL_DNS_VALUE"
    fi
    echo -e "[*] DNS: ${zsh}$DNS${endc}"
    if [ "$NO_BLOCK_WEBRTC" = "false" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Заблокирован WebRTC: ${gz}ДА${endc}" || echo -e "[*] Block WebRTC: ${gz}YES${endc}"
    else
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] Заблокирован WebRTC: ${rz}НЕТ${endc}" || echo -e "[*] Block WebRTC: ${rz}NO${endc}"
    fi
    CHECKVPN=$(sudo ifconfig | egrep -o "wg0|wg1|tun0|tun1|tap0|tap1|ppp0|ppp1|vti0|pr0|ss0|ssh0")
    if [ -n "$CHECKVPN" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] VPN/TUN: ${gz}ДА${endc}" || echo -e "[*] VPN/TUN: ${gz}YES${endc}"
      IPINET=$(ifconfig $CHECKVPN | grep "inet " | awk '{print $2}' | cut -d/ -f1)
    else
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] VPN/TUN: ${rz}НЕТ${endc}" || echo -e "[*] VPN/TUN: ${rz}NO${endc}"
    fi
    checkipt=$(sudo iptables -t nat -L PREROUTING | egrep -o "PROXYNEY")
    sudo iptables -t nat -L $checkipt 1>/dev/null 2>&1
    if [ -n "$checkipt" ]; then
      echo [*]
      sudo bash -c "sudo proxyney -s" 1>/dev/null 2>&1
      #sudo bash -c "sudo proxydney -s" 1>/dev/null 2>&1
      #sudo bash -c "sudo ssdney -s" 1>/dev/null 2>&1
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Информация:${endc} Сейчас $checkipt отсоединен..." || echo -e "[*] ${yz}Information:${endc} Currently $checkipt is disconnected..."
    fi
    sudo iptables -t nat -L $IPTNAME 1>/dev/null 2>&1
    if [ "$?" != "0" ]; then
      echo [*]
    else
      stop_ssney
      stop_iptsecurity
      CHECKWEBRTCOFF=$(sudo iptables -t raw -L PREROUTING | egrep -o "3478,19302,19305")
      if [ -n "$CHECKWEBRTCOFF" ]; then
        stop_webrtcoff
      fi
      echo "[*]"
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Рестарт...${endc}" || echo -e "[*] ${yz}Restart...${endc}"
    fi
    SSNEY_PORT=$(expr $SERVERPORT + 1)
    TMP=/tmp/ssney ; mkdir -p $TMP
    SSNEY_CONF=$TMP/ssney
cat > $SSNEY_CONF <<EOF
{
"locals": [
        {
            "protocol": "socks",
            "local_address": "$LSERVER",
            "local_port": $SSNEY_PORT,
            "mode": "tcp_and_udp",
            "local_udp_address": "$LSERVER",
            "local_udp_port": $SSNEY_PORT,
        }
],
"server": "$SERVERIP", "server_port": $SERVERPORT,
"password": "$SERVERPASS",
"method": "$METHOD",
"ipv6_first": false,
"ipv6_only": false,
$mode_str1
$plugin_str1
$plugin_str2
}
EOF
    PROXYFORSSNEY_PORT=$(expr $SSNEY_PORT + 1)
    TMP=/tmp/${0##*/} ; mkdir -p $TMP
    PROXYFORSSNEY_CONF=$TMP/proxyforssney
cat > $PROXYFORSSNEY_CONF <<EOF
daemon
internal $LSERVER
external $IPINET
nserver $LOCALDNS
nscache 65535
timeouts 1 5 30 60 180 1800 15 60
auth iponly
dnspr -i$LSERVER -p$LPDNS
allow *
parent 1000 socks5 $LSERVER $SSNEY_PORT
plugin /usr/local/3proxy/libexec/TransparentPlugin.ld.so transparent_plugin
transparent
tcppm -i$LSERVER $PROXYFORSSNEY_PORT 127.0.0.1 11111
notransparent
tcppm -i$LSERVER $LPDNS $DNS 53
socks -n -a -p4128
EOF
    start_ssney
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Подключаемся к серверу по Shadowsocks..." || echo -e "[*] Connecting to the server by Shadowsocks..."
    if curl --output /dev/null --silent --max-time 8 --socks5 $LSERVER:4128 --head --fail https://1.1.1.1 2>&1 || curl --output /dev/null --silent --max-time 8 --socks5 $LSERVER:4128 --head --fail https://8.8.8.8 2>&1 || curl --output /dev/null --silent --max-time 8 --socks5 $LSERVER:4128 --head --fail https://debian.org 2>&1 ; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Валид.${endc}" || echo -e "[*] ${gz}Valid.${endc}"
    else
      stop_ssney
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Не валид.${endc}" || echo -e "[*] ${rz}Invalid.${endc}"
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Информация: не удалось подключиться к серверу по Shadowsocks.${endc}" || echo -e "[*] ${rz}Information: failed to connect to the server by Shadowsocks.${endc}"
      echo -e "`date +%T`  `date +%d-%m-%Y`  NO VALID = ssney $LASTCMD" >> $HISTORY/ssney-h
      echo =================================
      exit 1
    fi
    sudo touch /tmp/ssney/ssney-online 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Подключен к серверу по Shadowsocks." || echo -e "[*] ${gz}Done:${endc} Connected to the server by Shadowsocks."
    start_iptsecurity
    if [ "$NO_BLOCK_WEBRTC" = "false" ]; then
      start_webrtcoff
    fi
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] Время: `date +%T` `date +%d-%m-%Y`" || echo -e "[*] Time: `date +%T` `date +%d-%m-%Y`"
    if [ -n $checkwebrtc ]; then
      echo -e "`date +%T`  `date +%d-%m-%Y`  VALID = ssney $LASTCMD" >> $HISTORY/ssney-h
    else
      echo -e "`date +%T`  `date +%d-%m-%Y`  VALID = ssney $LASTCMD" >> $HISTORY/ssney-h
    fi
    #echo [*] 'Остановить Shadowsocks - sudo ssney -s'
    echo =================================
    shift 2
    exit 1
    ;;
    -s|stop)
    stop_ssney
    stop_iptsecurity
    CHECKWEBRTCOFF=$(sudo iptables -t raw -L PREROUTING | egrep -o "3478,19302,19305")
    if [ -n "$CHECKWEBRTCOFF" ]; then
      stop_webrtcoff
    fi
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Shadowsocks-клиент отсоединен." || echo -e "[*] ${gz}Done:${endc} Shadowsocks-client disconnected."
    echo =================================
    shift
    exit 1
    ;;

    stop-ss-ssd)
    # Проверка статуса подключения ssney и ssdney
    [ -f "/tmp/ssney/ssney-online" ] && SS_STATUS="ON" || SS_STATUS="OFF"
    [ -f "/tmp/ssdney/ssdney-online" ] && SSD_STATUS="ON" || SSD_STATUS="OFF"
    
    if [ "$SS_STATUS" = "ON" ] && [ "$SSD_STATUS" = "ON" ]; then
        # Если активны оба, спрашиваем, что отключить
        
        #echo -e [*] ''$bz'Выберите тип отсоединения:'$endc''
        #echo -e "1) Отсоединить только ssney"
        #echo -e "2) Отсоединить все (ssney и ssdney)"
        #read -p "Введите ваш выбор (1/2): " choice_stop
      if [ "$LANGUAGE" = "RU" ]; then
        FZF_HEADER="
enter: выбрать
ESC: выход
      Выберите тип отсоединения:"
        BORDER_LABEL="| Менеджер Shadowsocks-клиент |"
        INTERACTIVE=" [1]  Отсоединить только TCP (ssney)
 [2]  Отсоединить все (ssney (TCP) и ssdney (TUN - TCP и UDP))"
      else
        FZF_HEADER="
enter: select
ESC: exit
      Stop configuration:"
        BORDER_LABEL="| Shadowsocks-client manager |"
        INTERACTIVE=" [1]  Stop only TCP (ssney)
 [2]  Stop all (ssney (TCP) and ssdney (TUN - TCP and UDP))"
      fi
      choice_stop=$(echo "$INTERACTIVE" | fzf --ansi --pointer=">" \
          --header="$FZF_HEADER" \
          --bind 'enter:become(echo {})' \
          --layout=reverse --border --border-label-pos=10 --border-label="$BORDER_LABEL" \
          --height=40% --info=inline --margin=1 --padding=1)
      if [ -z "$choice_stop" ]; then
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] Выход." || echo -e "[*] Exit."
        echo =================================
        exit 0
      fi
        case $choice_stop in
            *"[1]"*)
                sudo ssney -q -s
                ;;
            *"[2]"*)
                sudo ssney -q -s
                sudo ssdney -q -s
                ;;
        esac
    elif [ "$SS_STATUS" = "ON" ]; then
        # Если активен только ssney
        sudo ssney -q -s
    elif [ "$SSD_STATUS" = "ON" ]; then
        # Если активен только ssdney
        sudo ssdney -q -s
    else
        # Если ничего не активно
        [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${yz}Информация:${endc} Нет активных подключений Shadowsocks." || echo -e "[*] ${yz}Information:${endc} No active Shadowsocks connections."
    fi
    shift
    exit 1 ;;

#    enable)
#    HISTORYSS=$(cat $HISTORY/ssney-h 2>/dev/null | sort -r | sed "s/NO ASN/$(echo -e "$yz")NO ASN$(echo -e "$endc")/g" | sed "s/NO AUTO DNS/$(echo -e "$yz")NO AUTO DNS$(echo -e "$endc")/g" | sed "s/NO VALID/$(echo -e "$rz")NO VALID$(echo -e "$endc")/g" | sed "s/  VALID/$(echo -e "$gz")  VALID$(echo -e "$endc")/g" | fzf \
#      --header=$'Press ENTER to select Shadowsocks for autoconnect or press ESC to exit\n\n' \
#      --layout=default --height=40% --info=inline --border --margin=1 --padding=1 --ansi)
#    if [ -z "$HISTORYSS" ]; then
#      echo -e [*] 'Exit.'
#      echo =================================
#      exit 1
#    fi
#    TUSS=$(echo "$HISTORYSS" | cut -d= -f2)
#    autossney=$(sudo cat /etc/rc.local | grep "sudo ss")
#    if [ -z "$autossney" ]; then
#      sudo sed -i -e '$i\sudo ss\n' /etc/rc.local
#      sudo sed -i /etc/rc.local -e "/sudo ss/c sudo$TUSS" 1>/dev/null 2>&1
#    else
#      sudo sed -i /etc/rc.local -e "/sudo ss/c sudo$TUSS" 1>/dev/null 2>&1
#    fi
#    echo -e [*] $gz'OK!'$endc
#    echo -e [*] 'Autostart Shadowsocks: '$zsh''enable''$endc''
#    echo =================================
#    shift
#    exit 1 ;;
#    disable)
#    #sudo sed -i '/sudo ss/s/^/#/' /etc/rc.local
#    sudo sed -i /etc/rc.local -e "/sudo ss/c #sudo ssney" 1>/dev/null 2>&1
#    echo -e [*] $gz'OK!'$endc
#    echo -e [*] 'Autostart Shadowsocks: '$zsh''disable''$endc''
#    echo =================================
#    shift
#    exit 1 ;;
    clear)
    sudo sh -c "echo > $HISTORY/ssney-h 1>/dev/null 2>&1"
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} История очищена." || echo -e "[*] ${gz}Done:${endc} History cleared."
    echo =================================
    shift
    exit 1
    ;;
    import)
    if [ ! "$(ls -A $HOMENEY/shadowsocks-history 2>/dev/null)" ]; then
      [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${rz}Ошибка: не удалось найти файл shadowsocks-history.${endc}" || echo -e "[*] ${rz}Error: failed to find shadowsocks-history file.${endc}"
      echo =================================
      exit 1
    fi
    sudo cp $HOMENEY/shadowsocks-history $HISTORY/ssney-h 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Импорт выполнен." || echo -e "[*] ${gz}Done:${endc} Import completed."
    echo =================================
    shift
    exit 1 ;;
    export)
    sudo cp $HISTORY/ssney-h $HOMENEY/shadowsocks-history 1>/dev/null 2>&1
    [ "$LANGUAGE" = "RU" ] && echo -e "[*] ${gz}Успешно:${endc} Экспорт выполнен. Файл shadowsocks-history в домашней папке." || echo -e "[*] ${gz}Done:${endc} Export completed. shadowsocks-history file in home directory."
    echo =================================
    shift
    exit 1 ;;
    *) usage
    shift
    exit 1
    ;;
esac
done
exit 0;
